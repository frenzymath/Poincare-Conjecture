import Mathlib.Geometry.Manifold.ContMDiff.Atlas
import Mathlib.Geometry.Manifold.Instances.Real
import Mathlib.Analysis.Calculus.Deriv.Pow
import Mathlib.Topology.Order.IntermediateValue
import Mathlib.Order.Filter.AtTopBot.Ring
import LeeSmoothLib.Ch01.Sec01_04.Example_1_23_extra_1
-- Declarations for this item will be appended below by the statement pipeline.

open Filter ChartedSpace Topology
open scoped Manifold ContDiff

noncomputable section

/-- Helper for Example 1.23: the cubic map on `ℝ` is surjective. -/
lemma cubicMap_surjective : Function.Surjective cubicMap := by
  -- The odd cubic polynomial tends to `+∞` at `+∞` and to `-∞` at `-∞`.
  refine Continuous.surjective ?_ ?_ ?_
  · -- Continuity is immediate from the continuity of powers.
    simpa [cubicMap] using (continuous_id.pow (3 : ℕ) : Continuous fun x : ℝ ↦ x ^ (3 : ℕ))
  · -- Positive cubic growth gives the `atTop` behavior.
    simpa only [cubicMap] using
      (tendsto_pow_atTop (n := 3) (by norm_num : (3 : ℕ) ≠ 0) :
        Tendsto (fun x : ℝ ↦ x ^ (3 : ℕ)) atTop atTop)
  · -- Rewriting `x^3` as `-((-x)^3)` transfers the previous limit to `atBot`.
    have hpow :
        Tendsto (fun x : ℝ ↦ (-x) ^ (3 : ℕ)) atBot atTop := by
      exact (tendsto_pow_atTop (n := 3) (by norm_num : (3 : ℕ) ≠ 0)).comp
        tendsto_neg_atBot_atTop
    have hneg :
        Tendsto (fun x : ℝ ↦ -((-x) ^ (3 : ℕ))) atBot atBot := by
      exact tendsto_neg_atTop_atBot.comp hpow
    have hcubic :
        (fun x : ℝ ↦ -((-x) ^ (3 : ℕ))) = cubicMap := by
      funext x
      ring_nf
      simp [cubicMap]
    rw [← hcubic]
    exact hneg

-- Proof sketch: use strict monotonicity of `x ↦ x^3` on `ℝ` to obtain an order isomorphism, hence
-- a homeomorphism, and conclude that the cubic map is an open embedding.
/-- The cubic map is an open embedding of `ℝ` into itself. -/
theorem cubicMap_isOpenEmbedding : IsOpenEmbedding cubicMap := by
  -- Strict monotonicity identifies the cubic map with an order isomorphism of `ℝ`.
  let cubicOrderIso : ℝ ≃o ℝ :=
    ((show Odd (3 : ℕ) by decide).strictMono_pow (R := ℝ)).orderIsoOfSurjective
      cubicMap cubicMap_surjective
  -- Order isomorphisms of `ℝ` are homeomorphisms, so their underlying maps are open embeddings.
  simpa [cubicOrderIso, cubicMap] using cubicOrderIso.toHomeomorph.isOpenEmbedding

/-- The charted-space structure on `ℝ` generated by the single cubic chart. -/
@[implicit_reducible] def cubicChartedSpace : ChartedSpace ℝ ℝ :=
  cubicMap_isOpenEmbedding.singletonChartedSpace

/-- The unique chart in the cubic charted-space structure on `ℝ`. -/
def cubicChart : OpenPartialHomeomorph ℝ ℝ :=
  cubicMap_isOpenEmbedding.toOpenPartialHomeomorph cubicMap

/-- The singleton atlas generated by the cubic chart defines a smooth manifold structure on `ℝ`. -/
instance cubicChartedSpace_isManifold :
    @IsManifold ℝ _ ℝ _ _ ℝ _ (𝓘(ℝ)) ∞ ℝ _ cubicChartedSpace :=
  cubicMap_isOpenEmbedding.isManifold_singleton

/-- Lee's alternate smooth real line `\widetilde{ℝ}` from Example 1.23, realized on the
underlying set `ℝ` with the singleton cubic-chart smooth structure. -/
def CubicRealLine := ℝ

instance : TopologicalSpace CubicRealLine := by
  delta CubicRealLine
  infer_instance

instance : ChartedSpace ℝ CubicRealLine := by
  delta CubicRealLine
  exact cubicChartedSpace

instance : IsManifold (𝓘(ℝ)) ∞ CubicRealLine := by
  delta CubicRealLine
  exact cubicChartedSpace_isManifold

/-- Helper for Example 1.23: the target of the cubic chart is all of `ℝ`. -/
lemma cubicChart_target_eq_univ : cubicChart.target = Set.univ := by
  -- Surjectivity upgrades the target of the partial homeomorphism to all of `ℝ`.
  rw [cubicChart, cubicMap_isOpenEmbedding.toOpenPartialHomeomorph_target]
  exact cubicMap_surjective.range_eq

/-- Helper for Example 1.23: the inverse cubic chart is a global cube root. -/
lemma cubicChart_symm_cube_eq (y : ℝ) : (cubicChart.symm y) ^ (3 : ℕ) = y := by
  -- The right inverse formula applies at every `y` because the cubic map is surjective.
  have hy : y ∈ Set.range cubicMap := by
    rw [cubicMap_surjective.range_eq]
    exact Set.mem_univ y
  simpa [cubicChart, cubicMap] using
    cubicMap_isOpenEmbedding.toOpenPartialHomeomorph_right_inv (f := cubicMap) hy

/-- Helper for Example 1.23: the inverse cubic chart fixes the origin. -/
lemma cubicChart_symm_zero : cubicChart.symm 0 = 0 := by
  -- Injectivity of the cubic map reduces the pointwise claim to the cubic identity.
  apply cubicMap_isOpenEmbedding.injective
  simpa [cubicMap] using cubicChart_symm_cube_eq 0

-- Proof sketch: identify the transition map from the cubic chart to the standard chart with the
-- inverse partial homeomorphism `cubicChart.symm`, i.e. the cube-root map, and use the classical
-- failure of differentiability at `0`.
/-- The inverse of the cubic chart, viewed as a transition map to the standard chart, is not
smooth at `0`. -/
theorem cubicChart_symm_not_contDiffAt_zero :
    ¬ ContDiffAt ℝ ∞ cubicChart.symm 0 := by
  intro hcont
  -- Smoothness at `0` implies differentiability at `0`.
  have hderiv :
      HasDerivAt cubicChart.symm (deriv cubicChart.symm 0) 0 := by
    exact (hcont.differentiableAt (by simp)).hasDerivAt
  -- Differentiating the cubic identity forces the derivative of the identity at `0` to be `0`.
  have hcube :
      HasDerivAt (fun y : ℝ ↦ (cubicChart.symm y) ^ (3 : ℕ))
        ((3 : ℝ) * cubicChart.symm 0 ^ (2 : ℕ) * deriv cubicChart.symm 0) 0 := by
    simpa using hderiv.pow (3 : ℕ)
  have hid :
      HasDerivAt (fun y : ℝ ↦ y)
        ((3 : ℝ) * cubicChart.symm 0 ^ (2 : ℕ) * deriv cubicChart.symm 0) 0 := by
    refine hcube.congr_of_eventuallyEq ?_
    exact Filter.EventuallyEq.of_eq <| funext fun y ↦ (cubicChart_symm_cube_eq y).symm
  have hid_zero : HasDerivAt (fun y : ℝ ↦ y) 0 0 := by
    -- The factor `cubicChart.symm 0` vanishes, so the derivative coefficient is zero.
    refine hid.congr_deriv ?_
    simp [cubicChart_symm_zero]
  have hId : HasDerivAt (fun y : ℝ ↦ y) 1 0 := by
    simpa using hasDerivAt_id 0
  have : (0 : ℝ) = 1 := hid_zero.unique hId
  norm_num at this

-- Proof sketch: unfold `IsManifold.maximalAtlas (𝓘(ℝ)) ∞ ℝ` as the maximal atlas of the
-- standard smooth structure on `ℝ`, test smooth compatibility against the identity chart
-- `OpenPartialHomeomorph.refl ℝ`, and use `cubicChart_symm_not_contDiffAt_zero` to rule out
-- membership.
/-- Example 1.23: the cubic chart does not belong to the maximal smooth atlas of the standard
smooth structure on `ℝ`, so the singleton cubic atlas defines a different smooth structure. -/
theorem cubicChart_not_mem_standard_smooth_maximalAtlas :
    cubicChart ∉ IsManifold.maximalAtlas (𝓘(ℝ)) ∞ ℝ := by
  intro hmem
  -- Membership in the maximal standard atlas would force the inverse chart to be smooth at `0`.
  have hsymm :
      ContDiffAt ℝ ∞ cubicChart.symm 0 := by
    simpa [contMDiffAt_iff_contDiffAt] using
      (contMDiffAt_symm_of_mem_maximalAtlas (I := 𝓘(ℝ)) (n := ∞) (e := cubicChart) hmem <| by
        rw [cubicChart_target_eq_univ]
        exact Set.mem_univ 0)
  exact cubicChart_symm_not_contDiffAt_zero hsymm

end
