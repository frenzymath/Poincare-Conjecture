import Mathlib

-- Declarations for this item will be appended below by the statement pipeline.

-- Domain sampling: the primary domain here is topological groups. The canonical owners checked
-- before refinement were `Subgroup.closure` for generated subgroups,
-- `Subgroup.isOpen_of_mem_nhds` for openness from a neighborhood,
-- `Subgroup.connectedComponentOfOne` for the identity component, and
-- `IsClopen.connectedComponent_subset` for clopen containment of connected components.

universe u_G

section

variable {G : Type u_G} [Group G] [TopologicalSpace G]

/-- Proposition 7.14 (1): if `W` is a neighborhood of the identity in a topological group `G`,
then the subgroup generated by `W`, namely `Subgroup.closure W`, is open. -/
theorem generatedSubgroup_isOpen_of_mem_nhds_one
    [SeparatelyContinuousMul G]
    (W : Set G) (hW : W ∈ nhds (1 : G)) :
    IsOpen ((Subgroup.closure W : Set G)) :=
  Subgroup.isOpen_of_mem_nhds (Subgroup.closure W) <|
    Filter.mem_of_superset hW Subgroup.subset_closure

/-- Proposition 7.14 (2): if `W` is a connected neighborhood of the identity in a topological
group `G`, then the subgroup generated by `W` is connected. -/
theorem generatedSubgroup_isConnected_of_mem_nhds_one
    [IsTopologicalGroup G]
    (W : Set G) (hW : W ∈ nhds (1 : G)) (hconn : IsConnected W) :
    IsConnected ((Subgroup.closure W : Set G)) := by
  let H : Subgroup G := Subgroup.closure W
  let C : Subgroup G := Subgroup.connectedComponentOfOne G
  have hWsub : W ⊆ (C : Set G) := fun x hx ↦ hconn.subset_connectedComponent
    (mem_of_mem_nhds hW) hx
  have hHle : H ≤ C := (Subgroup.closure_le C).2 hWsub
  have hHopen : IsOpen (H : Set G) := generatedSubgroup_isOpen_of_mem_nhds_one W hW
  have hHclopen : IsClopen (H : Set G) := ⟨Subgroup.isClosed_of_isOpen H hHopen, hHopen⟩
  have hCle : C ≤ H := fun x hx ↦ hHclopen.connectedComponent_subset (one_mem H) hx
  have hHC : H = C := le_antisymm hHle hCle
  change IsConnected (H : Set G)
  rw [hHC]
  change IsConnected (connectedComponent (1 : G))
  exact isConnected_connectedComponent

/-- Proposition 7.14 (3): if `G` is connected and `W` is a neighborhood of the identity, then `W`
generates all of `G`. -/
theorem generatedSubgroup_eq_top_of_mem_nhds_one
    [SeparatelyContinuousMul G] [ConnectedSpace G] (W : Set G) (hW : W ∈ nhds (1 : G)) :
    Subgroup.closure W = (⊤ : Subgroup G) := by
  let H : Subgroup G := Subgroup.closure W
  have hHopen : IsOpen (H : Set G) := generatedSubgroup_isOpen_of_mem_nhds_one W hW
  have hHclopen : IsClopen (H : Set G) := ⟨Subgroup.isClosed_of_isOpen H hHopen, hHopen⟩
  have hHuniv : (H : Set G) = Set.univ := hHclopen.eq_univ ⟨1, one_mem H⟩
  ext x
  change x ∈ (H : Set G) ↔ x ∈ Set.univ
  rw [hHuniv]

end
