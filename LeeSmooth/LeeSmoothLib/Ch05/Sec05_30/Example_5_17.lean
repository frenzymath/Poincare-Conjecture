import Mathlib
import LeeSmoothLib.Ch01.Sec01.Definition_1_extra_1
import LeeSmoothLib.Ch04.Sec04_21.Example_4_2
import LeeSmoothLib.Ch05.Sec05_28.Definition_5_28_extra_1
import LeeSmoothLib.Ch05.Sec05_30.Definition_5_30_extra_3
-- Declarations for this item will be appended below by the statement pipeline.

open Manifold
open scoped ContDiff Manifold

noncomputable section

local notation "R2" => EuclideanSpace ℝ (Fin 2)
local notation "R3" => EuclideanSpace ℝ (Fin 3)

-- Semantic recall note: `lean_leansearch` was unavailable in this environment, so the statement
-- shape was fixed from the local `Set.IsLocalDefiningMapOn`, `IsEmbeddedSubmanifold`, and
-- `torus_revolution_surface` APIs already present in this repository.

/-- The right half-plane `H = {(r,z) : r > 0}` used for generating curves of surfaces of
revolution. -/
def surface_revolution_half_plane : Set R2 :=
  {p | 0 < p 0}

/-- Membership in `surface_revolution_half_plane` is the positivity of the radial coordinate. -/
theorem mem_surface_revolution_half_plane_iff {p : R2} :
    p ∈ surface_revolution_half_plane ↔ 0 < p 0 := sorry

/-- The cylindrical-coordinate projection `(x,y,z) ↦ (sqrt (x^2 + y^2), z)`. -/
def surface_revolution_cylindrical (p : R3) : R2 :=
  WithLp.toLp 2 ![Real.sqrt (p 0 ^ 2 + p 1 ^ 2), p 2]

/-- The cylindrical-coordinate projection has the expected explicit coordinates. -/
theorem surface_revolution_cylindrical_apply (p : R3) :
    surface_revolution_cylindrical p =
      WithLp.toLp 2 ![Real.sqrt (p 0 ^ 2 + p 1 ^ 2), p 2] := sorry

/-- The surface of revolution generated by a subset `C ⊆ H`. -/
def surface_of_revolution (C : Set R2) : Set R3 :=
  {p | surface_revolution_cylindrical p ∈ C}

/-- Membership in `surface_of_revolution C` means that the cylindrical point
`(sqrt (x^2 + y^2), z)` lies in `C`. -/
theorem mem_surface_of_revolution_iff {C : Set R2} {p : R3} :
    p ∈ surface_of_revolution C ↔ surface_revolution_cylindrical p ∈ C := sorry

/-- The lifted open neighborhood `Ũ` on which the local defining function for the surface of
revolution is defined. -/
theorem isOpen_surface_of_revolution_local_domain (U : TopologicalSpace.Opens R2) :
    IsOpen {p : R3 | surface_revolution_cylindrical p ∈ U} := sorry

/-- The open subset `Ũ = {(x,y,z) : (sqrt (x^2 + y^2), z) ∈ U}` attached to an open
`U ⊆ ℝ^2`. -/
def surface_of_revolution_local_domain (U : TopologicalSpace.Opens R2) :
    TopologicalSpace.Opens R3 :=
  ⟨{p : R3 | surface_revolution_cylindrical p ∈ U},
    isOpen_surface_of_revolution_local_domain U⟩

/-- Membership in `surface_of_revolution_local_domain U` is exactly the cylindrical-membership
condition defining `Ũ`. -/
theorem mem_surface_of_revolution_local_domain_iff {U : TopologicalSpace.Opens R2} {p : R3} :
    p ∈ surface_of_revolution_local_domain U ↔ surface_revolution_cylindrical p ∈ U := sorry

/-- The lifted local defining function `Φ(x,y,z) = φ(sqrt (x^2 + y^2), z)`. -/
def surface_of_revolution_local_defining_function {U : TopologicalSpace.Opens R2}
    (φ : U → ℝ) :
    surface_of_revolution_local_domain U → ℝ :=
  fun p ↦ φ ⟨surface_revolution_cylindrical p.1, p.2⟩

/-- The lifted local defining function is computed by composing `φ` with the cylindrical
projection. -/
theorem surface_of_revolution_local_defining_function_apply {U : TopologicalSpace.Opens R2}
    (φ : U → ℝ) (p : surface_of_revolution_local_domain U) :
    surface_of_revolution_local_defining_function φ p =
      φ ⟨surface_revolution_cylindrical p.1, p.2⟩ := sorry

/-- The generating circle `(r - 2)^2 + z^2 = 1` from the torus example. -/
def torus_revolution_generating_curve : Set R2 :=
  {p | (p 0 - 2) ^ 2 + p 1 ^ 2 = 1}

/-- Membership in `torus_revolution_generating_curve` is the explicit circle equation. -/
theorem mem_torus_revolution_generating_curve_iff {p : R2} :
    p ∈ torus_revolution_generating_curve ↔ (p 0 - 2) ^ 2 + p 1 ^ 2 = 1 := sorry

/-- Example 5.17 (1): if `φ : U → ℝ` is a local defining function for `C` on an open subset
`U ⊆ H`, then `Φ(x,y,z) = φ (sqrt (x^2 + y^2), z)` is a local defining function for the surface
of revolution `S_C` on the lifted open subset `Ũ`. -/
@[reducible]
def surface_of_revolution_local_defining_map_on
    {C : Set R2} {U : TopologicalSpace.Opens R2} {φ : U → ℝ}
    (hU : (U : Set R2) ⊆ surface_revolution_half_plane)
    (hφ : Set.IsLocalDefiningMapOn (𝓡 2) 𝓘(ℝ, ℝ) C U φ) :
    Set.IsLocalDefiningMapOn
      (𝓡 3)
      𝓘(ℝ, ℝ)
      (surface_of_revolution C)
      (surface_of_revolution_local_domain U)
      (surface_of_revolution_local_defining_function φ) where
  level := hφ.level
  contMDiff := sorry
  isLevelSet := sorry
  surj_mfderiv := sorry

/-- The constructed local defining map for the surface of revolution has the same level as the
original local defining map on the generating curve. -/
theorem surface_of_revolution_local_defining_map_on_level
    {C : Set R2} {U : TopologicalSpace.Opens R2} {φ : U → ℝ}
    (hU : (U : Set R2) ⊆ surface_revolution_half_plane)
    (hφ : Set.IsLocalDefiningMapOn (𝓡 2) 𝓘(ℝ, ℝ) C U φ) :
    (surface_of_revolution_local_defining_map_on hU hφ).level = hφ.level := sorry

/-- Example 5.17 (2): if each point of the generating curve `C ⊆ H` admits a local defining
function on an open subset of the half-plane, then the surface of revolution `S_C ⊆ ℝ^3` carries
the structure of an embedded `2`-dimensional submanifold. -/
theorem surface_of_revolution_is_embedded_submanifold
    {C : Set R2}
    (hC : C ⊆ surface_revolution_half_plane)
    (hLocal :
      ∀ p ∈ C,
        ∃ U : TopologicalSpace.Opens R2, p ∈ U ∧
          ∃ hU : (U : Set R2) ⊆ surface_revolution_half_plane,
            ∃ φ : U → ℝ, Nonempty (Set.IsLocalDefiningMapOn (𝓡 2) 𝓘(ℝ, ℝ) C U φ)) :
    (∃ tm : TopologicalManifold 2 (surface_of_revolution C),
      let _ : TopologicalManifold 2 (surface_of_revolution C) := tm
      ∃ hs : IsManifold (𝓡 2) ∞ (surface_of_revolution C),
        let _ : IsManifold (𝓡 2) ∞ (surface_of_revolution C) := hs
        IsEmbeddedSubmanifold (𝓡 3) (𝓡 2) (surface_of_revolution C)) := sorry

/-- Example 5.17 (3): the standard torus of revolution from Example 4.2 is the surface of
revolution generated by the circle `(r - 2)^2 + z^2 = 1` in the half-plane. -/
theorem torus_revolution_surface_eq_surface_of_revolution :
    torus_revolution_surface = surface_of_revolution torus_revolution_generating_curve := sorry
