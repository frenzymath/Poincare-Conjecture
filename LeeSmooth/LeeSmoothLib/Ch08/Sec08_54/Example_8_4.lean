noncomputable section

-- Domain sampling pass:
-- * primary domain: smooth vector fields on the circle and their angle-coordinate description;
-- * inspected owner/API declarations: `Notation_8_54_extra_3` for the canonical bundled smooth
--   vector-field owner `Cₛ^∞⟮I; E, TangentSpace I⟯`, `Proposition_8_8` for the nearby smooth
--   vector-field operations on that owner, and `Problem_1_8.IsAngleFunction` / `Circle.exp_arg`
--   for the angle-coordinate bridge to `Circle.exp`;
-- * source-facing item: the specific circle angle vector field `d / dθ` on `S¹`;
-- * core/canonical owner: the bundled smooth tangent-bundle section
--   `Cₛ^∞⟮𝓡 1; EuclideanSpace ℝ (Fin 1), fun z : Circle ↦ TangentSpace (𝓡 1) z⟯`;
-- * primitive data is only the vector field itself, while smoothness is derived from that owner,
--   so the existential wrapper should be demoted to a companion theorem.

local notation "SmoothCircleVectorField" =>
  Cₛ^∞⟮𝓡 1; EuclideanSpace ℝ (Fin 1), fun z : Circle ↦ TangentSpace (𝓡 1) z⟯

/-- Helper for Example 8.4: the identity tangent fiber of `Circle` inherits the standard
seminormed additive structure from `EuclideanSpace ℝ (Fin 1)`. -/
local instance example84CircleGroupLieAlgebraSeminormedAddCommGroup :
    SeminormedAddCommGroup (GroupLieAlgebra (𝓡 1) Circle) :=
  inferInstanceAs (SeminormedAddCommGroup (EuclideanSpace ℝ (Fin 1)))

/-- Helper for Example 8.4: the identity tangent fiber of `Circle` inherits the standard normed
additive structure from `EuclideanSpace ℝ (Fin 1)`. -/
local instance example84CircleGroupLieAlgebraNormedAddCommGroup :
    NormedAddCommGroup (GroupLieAlgebra (𝓡 1) Circle) :=
  inferInstanceAs (NormedAddCommGroup (EuclideanSpace ℝ (Fin 1)))

/-- Helper for Example 8.4: the identity tangent fiber of `Circle` is the standard real normed
space of dimension one. -/
local instance example84CircleGroupLieAlgebraNormedSpace :
    NormedSpace ℝ (GroupLieAlgebra (𝓡 1) Circle) :=
  inferInstanceAs (NormedSpace ℝ (EuclideanSpace ℝ (Fin 1)))

/-- Helper for Example 8.4: the identity tangent fiber of `Circle` is finite-dimensional. -/
local instance example84CircleGroupLieAlgebraFiniteDimensional :
    FiniteDimensional ℝ (GroupLieAlgebra (𝓡 1) Circle) :=
  inferInstanceAs (FiniteDimensional ℝ (EuclideanSpace ℝ (Fin 1)))

/-- Helper for Example 8.4: the identity tangent fiber of `Circle` carries the standard
self-charted manifold structure needed to view constant identity-fiber vectors as smooth total-space
maps. -/
local instance example84CircleIdentityFiberChartedSpace :
    ChartedSpace (TangentSpace (𝓡 1) (1 : Circle)) (WithLp 2 (Fin 1 → ℝ)) := by
  change ChartedSpace (WithLp 2 (Fin 1 → ℝ)) (WithLp 2 (Fin 1 → ℝ))
  exact chartedSpaceSelf _

/-- Helper for Example 8.4: the unit tangent vector at the identity of `Circle` obtained by
differentiating `Circle.exp` at `0`. -/
def circleExpIdentityVelocity : GroupLieAlgebra (𝓡 1) Circle :=
  mfderiv (𝓘(ℝ)) (𝓡 1) Circle.exp 0 ((fromTangentSpace 0).symm 1)

/-- Helper for Example 8.4: the left-invariant vector field generated by
`circleExpIdentityVelocity` is smooth. -/
theorem circleAngleVectorField_contMDiff :
    ContMDiff (𝓡 1) (𝓡 1).tangent ∞
      (T% (mulInvariantVectorField circleExpIdentityVelocity)) := by
  let fg : Circle → TangentBundle (𝓡 1) Circle := fun g ↦
    (⟨g, 0⟩ : TangentBundle (𝓡 1) Circle)
  -- The zero vector over the moving base point is the zero section.
  have sfg : ContMDiff (𝓡 1) (𝓡 1).tangent ∞ fg := by
    simpa [fg, Bundle.zeroSection] using Bundle.contMDiff_zeroSection ℝ (TangentSpace (𝓡 1))
  let fv : Circle → TangentBundle (𝓡 1) Circle := fun _ ↦
    (⟨1, circleExpIdentityVelocity⟩ : TangentBundle (𝓡 1) Circle)
  -- A fixed vector in the identity fiber is smooth as a map into the total space.
  have sfv : ContMDiff (𝓡 1) (𝓡 1).tangent ∞ fv := by
    intro g0
    rw [Bundle.contMDiffAt_totalSpace]
    refine ⟨contMDiffAt_const, ?_⟩
    let e := trivializationAt (EuclideanSpace ℝ (Fin 1)) (TangentSpace (𝓡 1)) (1 : Circle)
    let h1 : (1 : Circle) ∈ e.baseSet := FiberBundle.mem_baseSet_trivializationAt' (1 : Circle)
    let L : TangentSpace (𝓡 1) (1 : Circle) →L[ℝ] EuclideanSpace ℝ (Fin 1) :=
      (e.linearEquivAt ℝ (1 : Circle) h1).toContinuousLinearMap
    simpa [fv, e, L, h1] using (L.contMDiffAt.comp g0 contMDiffAt_const)
  let F₁ : Circle → TangentBundle (𝓡 1) Circle × TangentBundle (𝓡 1) Circle := fun g ↦
    (fg g, fv g)
  have S₁ : ContMDiff (𝓡 1) ((𝓡 1).tangent.prod (𝓡 1).tangent) ∞ F₁ := sfg.prodMk sfv
  let F₂ : TangentBundle (𝓡 1) Circle × TangentBundle (𝓡 1) Circle →
      TangentBundle ((𝓡 1).prod (𝓡 1)) (Circle × Circle) :=
    (equivTangentBundleProd (𝓡 1) Circle (𝓡 1) Circle).symm
  have S₂ :
      ContMDiff ((𝓡 1).tangent.prod (𝓡 1).tangent) (((𝓡 1).prod (𝓡 1)).tangent) ∞ F₂ :=
    contMDiff_equivTangentBundleProd_symm
  let F₃ : TangentBundle ((𝓡 1).prod (𝓡 1)) (Circle × Circle) → TangentBundle (𝓡 1) Circle :=
    tangentMap ((𝓡 1).prod (𝓡 1)) (𝓡 1) (fun p : Circle × Circle ↦ p.1 * p.2)
  have S₃ : ContMDiff (((𝓡 1).prod (𝓡 1)).tangent) (𝓡 1).tangent ∞ F₃ := by
    -- This is the tangent map of circle multiplication.
    apply ContMDiff.contMDiff_tangentMap
    · simpa using contMDiff_mul (𝓡 1) ∞
    · simp
  let S := (S₃.comp S₂).comp S₁
  have hcomp :
      ((F₃ ∘ F₂) ∘ F₁) =
        (fun g : Circle ↦
          (⟨g, mulInvariantVectorField circleExpIdentityVelocity g⟩ :
            TangentBundle (𝓡 1) Circle)) := by
    funext g
    -- The tangent vector `(0, circleExpIdentityVelocity)` at `(g, 1)` is the tangent of the slice
    -- `y ↦ (g, y)`, so the tangent map of multiplication reduces to `d(L_g)_1`.
    calc
      ((F₃ ∘ F₂) ∘ F₁) g
          = tangentMap ((𝓡 1).prod (𝓡 1)) (𝓡 1) (fun p : Circle × Circle ↦ p.1 * p.2)
              (⟨(g, 1), (0, circleExpIdentityVelocity)⟩ :
                TangentBundle ((𝓡 1).prod (𝓡 1)) (Circle × Circle)) := by
            rfl
      _ = tangentMap ((𝓡 1).prod (𝓡 1)) (𝓡 1) (fun p : Circle × Circle ↦ p.1 * p.2)
            (tangentMap (𝓡 1) ((𝓡 1).prod (𝓡 1)) (fun y : Circle ↦ (g, y))
              (⟨1, circleExpIdentityVelocity⟩ : TangentBundle (𝓡 1) Circle)) := by
            rw [tangentMap_prod_right]
      _ = tangentMap (𝓡 1) (𝓡 1)
            (((fun p : Circle × Circle ↦ p.1 * p.2) ∘ fun y : Circle ↦ (g, y)))
            (⟨1, circleExpIdentityVelocity⟩ : TangentBundle (𝓡 1) Circle) := by
            simpa using
              (congrArg
                (fun h : TangentBundle (𝓡 1) Circle → TangentBundle (𝓡 1) Circle ↦
                  h (⟨1, circleExpIdentityVelocity⟩ : TangentBundle (𝓡 1) Circle))
                (tangentMap_comp
                  (((contMDiff_mul (𝓡 1) ∞).mdifferentiable (by simp)))
                  (mdifferentiable_const.prodMk mdifferentiable_id))).symm
      _ = tangentMap (𝓡 1) (𝓡 1) (fun x : Circle ↦ g * x)
            (⟨1, circleExpIdentityVelocity⟩ : TangentBundle (𝓡 1) Circle) := by
            rfl
      _ = (⟨g, mulInvariantVectorField circleExpIdentityVelocity g⟩ :
            TangentBundle (𝓡 1) Circle) := by
            apply Bundle.TotalSpace.ext
            · simp [tangentMap]
            · exact HEq.rfl
  simpa [S, hcomp] using S

/-- The global circle angle vector field `d / dθ`, bundled as a smooth tangent-bundle section on
`S¹`. In Example 8.4 it is characterized by pulling back to the unit tangent vector field on `ℝ`
along `Circle.exp`. -/
def circle_angle_vector_field : SmoothCircleVectorField :=
  ⟨mulInvariantVectorField circleExpIdentityVelocity, circleAngleVectorField_contMDiff⟩

/-- Helper for Example 8.4: evaluating `circle_angle_vector_field` along `Circle.exp` is the
derivative of the translated exponential curve through the identity. -/
private theorem circleAngleVectorField_applyExp_asTranslatedCurve (t : ℝ) :
    circle_angle_vector_field (Circle.exp t) =
      mfderiv (𝓘(ℝ)) (𝓡 1) (((fun z : Circle ↦ Circle.exp t * z) ∘ Circle.exp)) 0
        ((fromTangentSpace 0).symm 1) := by
  -- Evaluate the invariant field at `Circle.exp t` by differentiating left multiplication.
  have hmul : MDiffAt (fun z : Circle ↦ Circle.exp t * z) (1 : Circle) := by
    simpa using (mdifferentiableAt_mul_left (a := Circle.exp t) (b := (1 : Circle)))
  have hexp : MDiffAt Circle.exp 0 := by
    exact contMDiff_circleExp.contMDiffAt.mdifferentiableAt
      (show (∞ : ℕ∞ω) ≠ 0 by simp)
  have hcomp :
      mfderiv (𝓘(ℝ)) (𝓡 1) ((fun z : Circle ↦ Circle.exp t * z) ∘ Circle.exp) 0
        ((fromTangentSpace 0).symm 1) =
          mfderiv (𝓡 1) (𝓡 1) (fun z : Circle ↦ Circle.exp t * z) 1
            (mfderiv (𝓘(ℝ)) (𝓡 1) Circle.exp 0 ((fromTangentSpace 0).symm 1)) := by
    -- The chain rule moves the pullback computation from `0 : ℝ` to `1 : Circle`.
    exact mfderiv_comp_apply_of_eq (x := 0) (y := (1 : Circle))
      (I := 𝓘(ℝ)) (I' := 𝓡 1) (I'' := 𝓡 1)
      (g := fun z : Circle ↦ Circle.exp t * z) (f := Circle.exp) hmul hexp Circle.exp_zero
      ((fromTangentSpace 0).symm (1 : ℝ))
  -- Route correction: package the stable invariant-field computation before normalizing tangents.
  change mulInvariantVectorField circleExpIdentityVelocity (Circle.exp t) = _
  simpa [circleExpIdentityVelocity, mulInvariantVectorField] using hcomp.symm

/-- Helper for Example 8.4: real translation sends the unit tangent at `0` to the canonical unit
tangent at `t`. -/
private theorem mfderivRealConstAdd_applyUnit (t : ℝ) :
    mfderiv (𝓘(ℝ)) (𝓘(ℝ)) (fun s : ℝ ↦ t + s) 0
      (((fromTangentSpace (𝕜 := ℝ) (E := ℝ) (0 : ℝ)).symm) 1) =
        (((fromTangentSpace (𝕜 := ℝ) (E := ℝ) t).symm) 1) := by
  -- On the model line, translation has derivative `id`, and all tangent-fiber identifications are
  -- definitionally the standard one.
  rw [mfderiv_eq_fderiv (𝕜 := ℝ), fderiv_const_add (𝕜 := ℝ)]
  have hId : fderiv ℝ (fun s : ℝ ↦ s) 0 = ContinuousLinearMap.id ℝ ℝ := by
    change fderiv ℝ id (0 : ℝ) = ContinuousLinearMap.id ℝ ℝ
    exact fderiv_id (𝕜 := ℝ) (x := (0 : ℝ))
  rw [hId]
  apply (fromTangentSpace t).injective
  rfl

/-- Helper for Example 8.4: translating the parameter of `Circle.exp` by `t` pulls the derivative
at `0` back to the derivative of `Circle.exp` at `t`. -/
private theorem circleExpMfderivConstAdd (t : ℝ) :
    mfderiv (𝓘(ℝ)) (𝓡 1) (fun s : ℝ ↦ Circle.exp (t + s)) 0
      (((fromTangentSpace (𝕜 := ℝ) (E := ℝ) (0 : ℝ)).symm) 1) =
        mfderiv (𝓘(ℝ)) (𝓡 1) Circle.exp t
          (((fromTangentSpace (𝕜 := ℝ) (E := ℝ) t).symm) 1) := by
  -- Differentiate `Circle.exp ∘ (fun s ↦ t + s)` at `0` using the chain rule.
  have htranslation : MDiffAt (fun s : ℝ ↦ t + s) 0 := by
    rw [mdifferentiableAt_iff_differentiableAt]
    simpa using (differentiableAt_id.const_add t : DifferentiableAt ℝ (fun s : ℝ ↦ t + s) 0)
  have hexp : MDiffAt Circle.exp t := by
    exact contMDiff_circleExp.contMDiffAt.mdifferentiableAt
      (show (∞ : ℕ∞ω) ≠ 0 by simp)
  have htranslation_zero : (fun s : ℝ ↦ t + s) 0 = t := by
    simp
  have hcomp :
      mfderiv (𝓘(ℝ)) (𝓡 1) (Circle.exp ∘ (fun s : ℝ ↦ t + s)) 0
        (((fromTangentSpace (𝕜 := ℝ) (E := ℝ) (0 : ℝ)).symm) 1) =
          mfderiv (𝓘(ℝ)) (𝓡 1) Circle.exp t
            (mfderiv (𝓘(ℝ)) (𝓘(ℝ)) (fun s : ℝ ↦ t + s) 0
              (((fromTangentSpace (𝕜 := ℝ) (E := ℝ) (0 : ℝ)).symm) 1)) := by
    exact mfderiv_comp_apply_of_eq (x := 0) (y := t) (I := 𝓘(ℝ)) (I' := 𝓘(ℝ)) (I'' := 𝓡 1)
      (g := Circle.exp) (f := fun s : ℝ ↦ t + s) hexp htranslation htranslation_zero
      (((fromTangentSpace (𝕜 := ℝ) (E := ℝ) (0 : ℝ)).symm) (1 : ℝ))
  -- Replace the translation derivative by the canonical unit tangent at `t`.
  calc
    mfderiv (𝓘(ℝ)) (𝓡 1) (fun s : ℝ ↦ Circle.exp (t + s)) 0
        (((fromTangentSpace (𝕜 := ℝ) (E := ℝ) (0 : ℝ)).symm) 1)
        = mfderiv (𝓘(ℝ)) (𝓡 1) Circle.exp t
          (mfderiv (𝓘(ℝ)) (𝓘(ℝ)) (fun s : ℝ ↦ t + s) 0
            (((fromTangentSpace (𝕜 := ℝ) (E := ℝ) (0 : ℝ)).symm) 1)) := hcomp
    _ = mfderiv (𝓘(ℝ)) (𝓡 1) Circle.exp t
          (((fromTangentSpace (𝕜 := ℝ) (E := ℝ) t).symm) 1) := by
          rw [mfderivRealConstAdd_applyUnit]

/-- Helper for Example 8.4: pulling back `circle_angle_vector_field` along the standard
exponential parametrization recovers the constant unit tangent vector field on `ℝ`. -/
@[simp] theorem circle_angle_vector_field_apply_exp (t : ℝ) :
    circle_angle_vector_field (Circle.exp t) =
      mfderiv (𝓘(ℝ)) (𝓡 1) Circle.exp t ((fromTangentSpace t).symm 1) := by
  -- Evaluate the invariant field along `Circle.exp` and rewrite the translated curve in `ℝ`.
  have hadd :
      (fun s : ℝ ↦ Circle.exp t * Circle.exp s) = fun s : ℝ ↦ Circle.exp (t + s) := by
    funext s
    exact (Circle.exp_add t s).symm
  have htranslated :
      mfderiv (𝓘(ℝ)) (𝓡 1) (((fun z : Circle ↦ Circle.exp t * z) ∘ Circle.exp)) 0
        ((fromTangentSpace 0).symm 1) =
          mfderiv (𝓘(ℝ)) (𝓡 1) (fun s : ℝ ↦ Circle.exp (t + s)) 0
            ((fromTangentSpace 0).symm 1) := by
    change
      mfderiv (𝓘(ℝ)) (𝓡 1) (fun s : ℝ ↦ Circle.exp t * Circle.exp s) 0
        ((fromTangentSpace 0).symm 1) =
          mfderiv (𝓘(ℝ)) (𝓡 1) (fun s : ℝ ↦ Circle.exp (t + s)) 0
            ((fromTangentSpace 0).symm 1)
    rw [hadd]
    rfl
  exact
    (circleAngleVectorField_applyExp_asTranslatedCurve t).trans <|
      htranslated.trans <| by
        simpa using circleExpMfderivConstAdd t

/-- Example 8.4 (The Angle Coordinate Vector Field on the Circle): there is a globally defined
smooth vector field on `S¹` whose pullback along `Circle.exp` is the constant unit tangent vector
field on `ℝ`. -/
theorem example_8_4 :
    ∃ X : SmoothCircleVectorField, ∀ t : ℝ,
        X (Circle.exp t) =
          mfderiv (𝓘(ℝ)) (𝓡 1) Circle.exp t ((fromTangentSpace t).symm 1) := by
  exact ⟨circle_angle_vector_field, circle_angle_vector_field_apply_exp⟩

/-- Companion existence form of Example 8.4, derived from the main theorem `example_8_4`. -/
theorem exists_smooth_circle_angle_vector_field :
    ∃ X : SmoothCircleVectorField, ∀ t : ℝ,
        X (Circle.exp t) =
          mfderiv (𝓘(ℝ)) (𝓡 1) Circle.exp t ((fromTangentSpace t).symm 1) := by
  exact example_8_4

/-- In any local angle coordinate, `circle_angle_vector_field` is represented by the coordinate
vector field `d / dθ`. -/
theorem circle_angle_vector_field_eq_mfderiv_circleExp_of_isAngleFunction
    {U : TopologicalSpace.Opens Circle} {θ : U → ℝ}
    (hθ : IsAngleFunction θ) (z : U) :
    circle_angle_vector_field z =
      mfderiv (𝓘(ℝ)) (𝓡 1) Circle.exp (θ z)
        ((fromTangentSpace (θ z)).symm 1) := by
  -- Rewrite the base point using the angle-coordinate identity and then apply the pullback theorem.
  rw [← hθ.2 z]
  exact circle_angle_vector_field_apply_exp (θ z)
