import Mathlib
import Mathlib.Algebra.Lie.OfAssociative
import Mathlib.Algebra.Lie.Subalgebra
import Mathlib.LinearAlgebra.FiniteDimensional.Basic

-- Declarations for this item will be appended below by the statement pipeline.

open scoped Matrix

noncomputable section

universe u

local notation "gl2" => Matrix (Fin 2) (Fin 2) ℝ
local notation "E₁₁" => (!![1, 0; 0, 0] : gl2)
local notation "E₂₂" => (!![0, 0; 0, 1] : gl2)
local notation "E₁₂" => (!![0, 1; 0, 0] : gl2)

-- Domain sampling pass:
-- * source-facing layer: the three explicit model Lie subalgebras of `𝔤𝔩(2, ℝ)` appearing in
--   Lee's classification of one- and two-dimensional real Lie algebras;
-- * core/canonical owner: `LieSubalgebra.lieSpan`;
-- * primitive data: the concrete generators `E₁₁`, `E₂₂`, and `E₁₂`;
-- * derived API here: finrank, abelianity, and Lie-equivalence statements for those models.

/-- The one-dimensional model Lie subalgebra of `𝔤𝔩(2, ℝ)`, generated by `diag(1, 0)`. -/
def gl2_real_one_dimensional_lie_subalgebra : LieSubalgebra ℝ gl2 :=
  LieSubalgebra.lieSpan ℝ gl2 { E₁₁ }

/-- Helper for Problem 8-21: the matrix unit `E₁₁` is nonzero. -/
theorem e11_ne_zero : (E₁₁ : gl2) ≠ 0 := by
  -- Inspect the `(0, 0)` entry to detect the nonzero diagonal generator.
  intro h
  have h00 := congrFun (congrFun h 0) 0
  norm_num at h00

/-- Helper for Problem 8-21: the matrix unit `E₂₂` is nonzero. -/
theorem e22_ne_zero : (E₂₂ : gl2) ≠ 0 := by
  -- Inspect the `(1, 1)` entry to detect the nonzero diagonal generator.
  intro h
  have h11 := congrFun (congrFun h 1) 1
  norm_num at h11

/-- Helper for Problem 8-21: the matrix unit `E₁₂` is nonzero. -/
theorem e12_ne_zero : (E₁₂ : gl2) ≠ 0 := by
  -- Inspect the `(0, 1)` entry to detect the nonzero off-diagonal generator.
  intro h
  have h01 := congrFun (congrFun h 0) 1
  norm_num at h01

/-- Helper for Problem 8-21: the generator `E₁₁` commutes with itself. -/
theorem lie_e11_e11 : ⁅E₁₁, E₁₁⁆ = 0 := by
  -- Compute the commutator entrywise in `𝔤𝔩(2, ℝ)`.
  ext i j <;> fin_cases i <;> fin_cases j <;> simp [Ring.lie_def, Matrix.mul_apply]

/-- Helper for Problem 8-21: the diagonal generators `E₁₁` and `E₂₂` commute. -/
theorem lie_e11_e22 : ⁅E₁₁, E₂₂⁆ = 0 := by
  -- Compute the commutator entrywise in `𝔤𝔩(2, ℝ)`.
  ext i j <;> fin_cases i <;> fin_cases j <;> simp [Ring.lie_def, Matrix.mul_apply]

/-- Helper for Problem 8-21: the opposite diagonal commutator also vanishes. -/
theorem lie_e22_e11 : ⁅E₂₂, E₁₁⁆ = 0 := by
  -- Compute the commutator entrywise in `𝔤𝔩(2, ℝ)`.
  ext i j <;> fin_cases i <;> fin_cases j <;> simp [Ring.lie_def, Matrix.mul_apply]

/-- Helper for Problem 8-21: the generator `E₂₂` commutes with itself. -/
theorem lie_e22_e22 : ⁅E₂₂, E₂₂⁆ = 0 := by
  -- Compute the commutator entrywise in `𝔤𝔩(2, ℝ)`.
  ext i j <;> fin_cases i <;> fin_cases j <;> simp [Ring.lie_def, Matrix.mul_apply]

/-- Helper for Problem 8-21: the standard upper-triangular generators satisfy
`[E₁₁, E₁₂] = E₁₂`. -/
theorem lie_e11_e12 : ⁅E₁₁, E₁₂⁆ = E₁₂ := by
  -- Compute the commutator entrywise in `𝔤𝔩(2, ℝ)`.
  ext i j <;> fin_cases i <;> fin_cases j <;> simp [Ring.lie_def, Matrix.mul_apply]

/-- Helper for Problem 8-21: the opposite upper-triangular commutator is `-E₁₂`. -/
theorem lie_e12_e11 : ⁅E₁₂, E₁₁⁆ = -E₁₂ := by
  -- Compute the commutator entrywise in `𝔤𝔩(2, ℝ)`.
  ext i j <;> fin_cases i <;> fin_cases j <;> simp [Ring.lie_def, Matrix.mul_apply]

/-- Helper for Problem 8-21: the nilpotent generator `E₁₂` commutes with itself. -/
theorem lie_e12_e12 : ⁅E₁₂, E₁₂⁆ = 0 := by
  -- Compute the commutator entrywise in `𝔤𝔩(2, ℝ)`.
  ext i j <;> fin_cases i <;> fin_cases j <;> simp [Ring.lie_def, Matrix.mul_apply]

/-- Helper for Problem 8-21: the diagonal pair `E₁₁, E₂₂` is linearly independent. -/
theorem linearIndependent_e11_e22 : LinearIndependent ℝ (![E₁₁, E₂₂] : Fin 2 → gl2) := by
  -- In `Fin 2`, linear independence reduces to checking a nonzero second vector and
  -- excluding scalar collapse onto the first.
  rw [linearIndependent_fin2]
  constructor
  · simpa using e22_ne_zero
  · intro a h
    have h00 := congrFun (congrFun h 0) 0
    norm_num at h00

/-- Helper for Problem 8-21: the upper-triangular pair `E₁₁, E₁₂` is linearly independent. -/
theorem linearIndependent_e11_e12 : LinearIndependent ℝ (![E₁₁, E₁₂] : Fin 2 → gl2) := by
  -- In `Fin 2`, linear independence reduces to checking a nonzero second vector and
  -- excluding scalar collapse onto the first.
  rw [linearIndependent_fin2]
  constructor
  · simpa using e12_ne_zero
  · intro a h
    have h00 := congrFun (congrFun h 0) 0
    norm_num at h00

/-- The one-dimensional model subalgebra of `𝔤𝔩(2, ℝ)` has real dimension `1`. -/
theorem gl2_real_one_dimensional_lie_subalgebra_finrank :
    Module.finrank ℝ gl2_real_one_dimensional_lie_subalgebra = 1 := by
  change Module.finrank ℝ ↥((gl2_real_one_dimensional_lie_subalgebra : Submodule ℝ gl2)) = 1
  -- The singleton generator is abelian, so the Lie span equals the ordinary linear span.
  rw [show (gl2_real_one_dimensional_lie_subalgebra : Submodule ℝ gl2) =
      Submodule.span ℝ ({E₁₁} : Set gl2) by
        simpa [gl2_real_one_dimensional_lie_subalgebra] using
          (LieSubalgebra.coe_lieSpan_eq_span_of_forall_lie_eq_zero (R := ℝ) (L := gl2)
            (s := ({E₁₁} : Set gl2)) (by
              intro x hx y hy
              simp only [Set.mem_singleton_iff] at hx hy
              subst x
              subst y
              exact lie_e11_e11))]
  simpa using (finrank_span_singleton (K := ℝ) (v := E₁₁) e11_ne_zero)

/-- The abelian two-dimensional model Lie subalgebra of `𝔤𝔩(2, ℝ)`, generated by the two diagonal
matrix units. -/
def gl2_real_two_dimensional_abelian_lie_subalgebra : LieSubalgebra ℝ gl2 :=
  LieSubalgebra.lieSpan ℝ gl2 { E₁₁, E₂₂ }

/-- The abelian two-dimensional model subalgebra of `𝔤𝔩(2, ℝ)` has real dimension `2`. -/
theorem gl2_real_two_dimensional_abelian_lie_subalgebra_finrank :
    Module.finrank ℝ gl2_real_two_dimensional_abelian_lie_subalgebra = 2 := by
  let v : Fin 2 → gl2 := ![E₁₁, E₂₂]
  have hv : ({E₁₁, E₂₂} : Set gl2) = Set.range v := by
    ext x
    simp [v, or_left_comm, or_comm, or_assoc]
  change Module.finrank ℝ ↥((gl2_real_two_dimensional_abelian_lie_subalgebra : Submodule ℝ gl2)) = 2
  -- The diagonal generators commute, so the Lie span is the ordinary span of the two matrices.
  rw [show (gl2_real_two_dimensional_abelian_lie_subalgebra : Submodule ℝ gl2) =
      Submodule.span ℝ (Set.range v) by
        rw [gl2_real_two_dimensional_abelian_lie_subalgebra, hv]
        exact LieSubalgebra.coe_lieSpan_eq_span_of_forall_lie_eq_zero
          (R := ℝ) (L := gl2) (s := Set.range v) (by
            intro x hx y hy
            rcases hx with ⟨i, rfl⟩
            rcases hy with ⟨j, rfl⟩
            fin_cases i <;> fin_cases j <;>
              simp [v, lie_e11_e11, lie_e11_e22, lie_e22_e11, lie_e22_e22])]
  simpa using (finrank_span_eq_card (R := ℝ) (b := v) linearIndependent_e11_e22)

/-- The diagonal two-dimensional model Lie subalgebra is abelian. -/
theorem gl2_real_two_dimensional_abelian_lie_subalgebra_isLieAbelian :
    IsLieAbelian gl2_real_two_dimensional_abelian_lie_subalgebra := by
  let v : Fin 2 → gl2 := ![E₁₁, E₂₂]
  have hv : ({E₁₁, E₂₂} : Set gl2) = Set.range v := by
    ext x
    simp [v, or_left_comm, or_comm, or_assoc]
  -- It suffices to check that the two generators commute pairwise.
  rw [gl2_real_two_dimensional_abelian_lie_subalgebra, hv,
    LieSubalgebra.isLieAbelian_lieSpan_iff]
  intro x hx y hy
  rcases hx with ⟨i, rfl⟩
  rcases hy with ⟨j, rfl⟩
  fin_cases i <;> fin_cases j <;>
    simp [v, lie_e11_e11, lie_e11_e22, lie_e22_e11, lie_e22_e22]

/-- The nonabelian two-dimensional model Lie subalgebra of `𝔤𝔩(2, ℝ)`, generated by `diag(1, 0)`
and `E₁₂`. -/
def gl2_real_two_dimensional_nonabelian_lie_subalgebra : LieSubalgebra ℝ gl2 :=
  LieSubalgebra.lieSpan ℝ gl2 { E₁₁, E₁₂ }

/-- Helper for Problem 8-21: the upper-triangular model has underlying submodule
`span{E₁₁, E₁₂}`. -/
theorem gl2RealTwoDimensionalNonabelian_toSubmodule_eq_spanRange :
    (gl2_real_two_dimensional_nonabelian_lie_subalgebra : Submodule ℝ gl2) =
      Submodule.span ℝ (Set.range (![E₁₁, E₁₂] : Fin 2 → gl2)) := by
  let v : Fin 2 → gl2 := ![E₁₁, E₁₂]
  have hv : Set.range v = ({E₁₁, E₁₂} : Set gl2) := by
    ext x
    simp [v, or_left_comm, or_comm, or_assoc]
  rw [hv]
  have hclosed :
      ∀ {x y : gl2},
        x ∈ Submodule.span ℝ ({E₁₁, E₁₂} : Set gl2) →
        y ∈ Submodule.span ℝ ({E₁₁, E₁₂} : Set gl2) →
        ⁅x, y⁆ ∈ Submodule.span ℝ ({E₁₁, E₁₂} : Set gl2) := by
    intro x y hx hy
    rcases (Submodule.mem_span_pair).mp hx with ⟨a, b, rfl⟩
    rcases (Submodule.mem_span_pair).mp hy with ⟨c, d, rfl⟩
    refine (Submodule.mem_span_pair).mpr ?_
    refine ⟨0, a * d - b * c, ?_⟩
    -- Compute the commutator of two upper-triangular generators entrywise.
    ext i j <;> fin_cases i <;> fin_cases j <;>
      simp [Ring.lie_def, Matrix.mul_apply]
    all_goals ring
  let p : LieSubalgebra ℝ gl2 :=
    { carrier := Submodule.span ℝ ({E₁₁, E₁₂} : Set gl2)
      zero_mem' := by
        exact Submodule.zero_mem _
      add_mem' := by
        intro x y hx hy
        exact Submodule.add_mem _ hx hy
      smul_mem' := by
        intro a x hx
        exact Submodule.smul_mem _ a hx
      lie_mem' := by
        intro x y hx hy
        exact hclosed hx hy }
  apply le_antisymm
  · -- The Lie span sits inside the bracket-stable linear span of the generators.
    change gl2_real_two_dimensional_nonabelian_lie_subalgebra ≤ p
    exact LieSubalgebra.lieSpan_le.mpr <| by
      intro x hx
      have hx' : x = E₁₁ ∨ x = E₁₂ := by simpa using hx
      rcases hx' with rfl | rfl
      · exact Submodule.subset_span (by simp : E₁₁ ∈ ({E₁₁, E₁₂} : Set gl2))
      · exact Submodule.subset_span (by simp : E₁₂ ∈ ({E₁₁, E₁₂} : Set gl2))
  · -- The linear span is contained in the Lie span because both generators are present.
    refine Submodule.span_le.mpr ?_
    intro x hx
    have hx' : x = E₁₁ ∨ x = E₁₂ := by simpa using hx
    rcases hx' with rfl | rfl
    · exact LieSubalgebra.subset_lieSpan (by simp [gl2_real_two_dimensional_nonabelian_lie_subalgebra])
    · exact LieSubalgebra.subset_lieSpan (by simp [gl2_real_two_dimensional_nonabelian_lie_subalgebra])

/-- The nonabelian two-dimensional model subalgebra of `𝔤𝔩(2, ℝ)` has real dimension `2`. -/
theorem gl2_real_two_dimensional_nonabelian_lie_subalgebra_finrank :
    Module.finrank ℝ gl2_real_two_dimensional_nonabelian_lie_subalgebra = 2 := by
  change Module.finrank ℝ ↥((gl2_real_two_dimensional_nonabelian_lie_subalgebra : Submodule ℝ gl2)) = 2
  -- Use the explicit span description of the upper-triangular model.
  rw [gl2RealTwoDimensionalNonabelian_toSubmodule_eq_spanRange]
  simpa using (finrank_span_eq_card (R := ℝ) (b := (![E₁₁, E₁₂] : Fin 2 → gl2))
    linearIndependent_e11_e12)

/-- The upper-triangular two-dimensional model Lie subalgebra is not abelian. -/
theorem gl2_real_two_dimensional_nonabelian_lie_subalgebra_not_isLieAbelian :
    ¬ IsLieAbelian gl2_real_two_dimensional_nonabelian_lie_subalgebra := by
  intro h
  let x : gl2_real_two_dimensional_nonabelian_lie_subalgebra :=
    ⟨E₁₁, LieSubalgebra.subset_lieSpan (by simp [gl2_real_two_dimensional_nonabelian_lie_subalgebra])⟩
  let y : gl2_real_two_dimensional_nonabelian_lie_subalgebra :=
    ⟨E₁₂, LieSubalgebra.subset_lieSpan (by simp [gl2_real_two_dimensional_nonabelian_lie_subalgebra])⟩
  -- The chosen generators witness a nonzero bracket inside the model.
  have hxy : ⁅x, y⁆ = 0 := h.1 x y
  have hy_zero : (y : gl2_real_two_dimensional_nonabelian_lie_subalgebra) = 0 := by
    simpa [x, y, Subtype.ext_iff, lie_e11_e12] using hxy
  exact e12_ne_zero <| by
    simpa [y] using congrArg Subtype.val hy_zero

section Helpers

variable {L₁ L₂ : Type*} [LieRing L₁] [LieRing L₂] [LieAlgebra ℝ L₁] [LieAlgebra ℝ L₂]
  [FiniteDimensional ℝ L₁] [FiniteDimensional ℝ L₂]

/-- Helper for Problem 8-21: in a `Fin 2` basis, every vector is the sum of its two coordinate
terms. -/
theorem finTwoBasis_repr (b : Module.Basis (Fin 2) ℝ L₁) (x : L₁) :
    x = (b.repr x 0) • b 0 + (b.repr x 1) • b 1 := by
  -- Specialize the basis expansion formula to the two-element index type `Fin 2`.
  calc
    x = ∑ i, (b.repr x i) • b i := by simpa using (b.sum_repr x).symm
    _ = (b.repr x 0) • b 0 + (b.repr x 1) • b 1 := by rw [Fin.sum_univ_two]

/-- Helper for Problem 8-21: a one-dimensional real Lie algebra is abelian. -/
theorem isLieAbelian_of_finrank_eq_one (h : Module.finrank ℝ L₁ = 1) :
    IsLieAbelian L₁ := by
  let b := Module.finBasisOfFinrankEq ℝ L₁ h
  have hb0 : b 0 ≠ 0 := b.ne_zero 0
  refine ⟨fun x y ↦ ?_⟩
  -- Express both elements as multiples of the unique basis vector.
  obtain ⟨a, rfl⟩ := exists_smul_eq_of_finrank_eq_one (K := ℝ) (V := L₁) h hb0 x
  obtain ⟨c, rfl⟩ := exists_smul_eq_of_finrank_eq_one (K := ℝ) (V := L₁) h hb0 y
  simp [lie_smul, smul_lie]

/-- Helper for Problem 8-21: equal-dimensional abelian real Lie algebras are Lie-isomorphic. -/
theorem nonemptyLieEquivOfFinrankEqOfIsLieAbelian
    (h₁ : IsLieAbelian L₁) (h₂ : IsLieAbelian L₂)
    (hfin : Module.finrank ℝ L₁ = Module.finrank ℝ L₂) :
    Nonempty (L₁ ≃ₗ⁅ℝ⁆ L₂) := by
  rcases FiniteDimensional.nonempty_linearEquiv_of_finrank_eq (R := ℝ) hfin with ⟨e⟩
  -- Upgrade the linear equivalence to a Lie equivalence because both brackets vanish.
  let f : L₁ →ₗ⁅ℝ⁆ L₂ :=
    { toLinearMap := e.toLinearMap
      map_lie' := by
        intro x y
        simp [h₁.1 x y, h₂.1 (e x) (e y)] }
  exact ⟨LieEquiv.ofBijective f e.bijective⟩

end Helpers

/-- Helper for Problem 8-21: if the cross-bracket of a `Fin 2` basis vanishes, then the Lie
algebra is abelian. -/
theorem isLieAbelian_of_finTwoBasisBracketZero
    {L : Type*} [LieRing L] [LieAlgebra ℝ L] [FiniteDimensional ℝ L]
    (b : Module.Basis (Fin 2) ℝ L) (h01 : ⁅b 0, b 1⁆ = 0) : IsLieAbelian L := by
  have h10 : ⁅b 1, b 0⁆ = 0 := by
    calc
      ⁅b 1, b 0⁆ = -⁅b 0, b 1⁆ := by rw [lie_skew]
      _ = 0 := by simp [h01]
  -- Expand both arguments in the chosen basis and use the vanishing mixed brackets.
  refine ⟨fun x y ↦ ?_⟩
  rw [finTwoBasis_repr b x, finTwoBasis_repr b y]
  simp [lie_add, add_lie, lie_smul, smul_lie, h01, h10]

/-- Helper for Problem 8-21: if `⁅b 0, b 1⁆ = a • b 0 + c • b 1` with `c ≠ 0`, then rescaling
`b 0` and taking the bracket vector as the second basis vector produces a normalized basis. -/
theorem normalizedBasisOfBracketSecondCoeffNeZero
    {L : Type*} [LieRing L] [LieAlgebra ℝ L] [FiniteDimensional ℝ L]
    (b : Module.Basis (Fin 2) ℝ L) (hfin : Module.finrank ℝ L = 2) {a c : ℝ}
    (hc : c ≠ 0) (hy : ⁅b 0, b 1⁆ = a • b 0 + c • b 1) :
    ∃ b' : Module.Basis (Fin 2) ℝ L, ⁅b' 0, b' 1⁆ = b' 1 := by
  let y : L := ⁅b 0, b 1⁆
  have hy' : y = a • b 0 + c • b 1 := by
    simpa [y] using hy
  have hy_ne : y ≠ 0 := by
    intro hy_zero
    have hEq : a • b 0 + c • b 1 = 0 := by
      rw [← hy', hy_zero]
    have h1 := congrArg (fun z => b.repr z 1) hEq
    simp [hc] at h1
  let v : Fin 2 → L := ![c⁻¹ • b 0, y]
  have hv_indep : LinearIndependent ℝ v := by
    rw [linearIndependent_fin2]
    constructor
    · simpa [v, y] using hy_ne
    · intro t ht
      have hEq : t • (a • b 0 + c • b 1) = c⁻¹ • b 0 := by
        simpa [v, y, hy'] using ht
      have h0 := congrArg (fun z => b.repr z 0) hEq
      have h1 := congrArg (fun z => b.repr z 1) hEq
      simp [hc] at h0 h1
      field_simp [hc] at h0
      subst t
      norm_num at h0
  let b' : Module.Basis (Fin 2) ℝ L :=
    basisOfLinearIndependentOfCardEqFinrank hv_indep (by simpa [hfin])
  refine ⟨b', ?_⟩
  have hb' : (b' : Fin 2 → L) = v := by
    simpa [b'] using
      (coe_basisOfLinearIndependentOfCardEqFinrank (K := ℝ) (lin_ind := hv_indep)
        (card_eq := by simpa [hfin]))
  rw [hb']
  -- The chosen scaling turns the unique nonzero bracket into the second basis vector.
  calc
    ⁅v 0, v 1⁆ = c⁻¹ • ⁅b 0, y⁆ := by simp [v, y]
    _ = c⁻¹ • (c • y) := by
      simp [y, hy', lie_add, add_lie, lie_smul, smul_lie]
    _ = y := by
      simp [hc, y]

/-- Helper for Problem 8-21: every nonabelian two-dimensional real Lie algebra admits a basis
`b` with `⁅b 0, b 1⁆ = b 1`. -/
theorem existsNormalizedBasisOfFinrankEqTwoNotIsLieAbelian
    {L : Type*} [LieRing L] [LieAlgebra ℝ L] [FiniteDimensional ℝ L]
    (hfin : Module.finrank ℝ L = 2) (hnab : ¬ IsLieAbelian L) :
    ∃ b : Module.Basis (Fin 2) ℝ L, ⁅b 0, b 1⁆ = b 1 := by
  let b := Module.finBasisOfFinrankEq ℝ L hfin
  let y : L := ⁅b 0, b 1⁆
  have hy_ne : y ≠ 0 := by
    intro hy_zero
    apply hnab
    apply isLieAbelian_of_finTwoBasisBracketZero b
    simpa [y] using hy_zero
  let a : ℝ := b.repr y 0
  let c : ℝ := b.repr y 1
  have hy' : y = a • b 0 + c • b 1 := by
    simpa [a, c] using finTwoBasis_repr b y
  have hcoeff : a ≠ 0 ∨ c ≠ 0 := by
    by_contra hzero
    push_neg at hzero
    have : y = 0 := by
      rw [hy', hzero.1, hzero.2]
      simp
    exact hy_ne this
  rcases hcoeff with ha | hc
  · let s : Equiv (Fin 2) (Fin 2) := Equiv.swap 0 1
    have hy'' : ⁅b 0, b 1⁆ = a • b 0 + c • b 1 := by
      simpa [y] using hy'
    have hswap :
        ⁅(b.reindex s) 0, (b.reindex s) 1⁆ =
          (-c) • (b.reindex s) 0 + (-a) • (b.reindex s) 1 := by
      simpa [s] using
        (show ⁅b 1, b 0⁆ = (-c) • b 1 + (-a) • b 0 from
          calc
            ⁅b 1, b 0⁆ = -⁅b 0, b 1⁆ := by rw [lie_skew]
            _ = -(a • b 0 + c • b 1) := by rw [hy'']
            _ = (-c) • b 1 + (-a) • b 0 := by
              simp [smul_add, add_comm, add_left_comm, add_assoc])
    exact normalizedBasisOfBracketSecondCoeffNeZero (b.reindex s) hfin
      (by simpa using ha) hswap
  · exact normalizedBasisOfBracketSecondCoeffNeZero b hfin hc (by simpa [y] using hy')

/-- Helper for Problem 8-21: a normalized basis with `⁅b 0, b 1⁆ = b 1` yields a Lie
equivalence to the standard nonabelian `gl(2, ℝ)` model. -/
theorem nonemptyLieEquivGl2NonabelianModelOfNormalizedBasis
    {L : Type*} [LieRing L] [LieAlgebra ℝ L] [FiniteDimensional ℝ L]
    (b : Module.Basis (Fin 2) ℝ L) (hb : ⁅b 0, b 1⁆ = b 1) :
    Nonempty (L ≃ₗ⁅ℝ⁆ gl2_real_two_dimensional_nonabelian_lie_subalgebra) := by
  let fLin : L →ₗ[ℝ] gl2 := b.constr ℝ (![E₁₁, E₁₂] : Fin 2 → gl2)
  have hb10 : ⁅b 1, b 0⁆ = -b 1 := by
    calc
      ⁅b 1, b 0⁆ = -⁅b 0, b 1⁆ := by rw [lie_skew]
      _ = -b 1 := by simp [hb]
  have hbracket_formula (x y : L) :
      ⁅x, y⁆ = ((b.repr x 0 * b.repr y 1 - b.repr x 1 * b.repr y 0)) • b 1 := by
    rw [finTwoBasis_repr b x, finTwoBasis_repr b y]
    simp [hb, hb10, lie_add, add_lie, lie_smul, smul_lie]
    have hs :
        -((b.repr y) 0 * (b.repr x) 1) + (b.repr y) 1 * (b.repr x) 0 =
          (b.repr x 0 * b.repr y 1 - b.repr x 1 * b.repr y 0) := by
      ring
    simpa [sub_eq_add_neg, add_smul, smul_add, smul_smul, mul_comm, mul_left_comm, mul_assoc] using
      congrArg (fun t : ℝ => t • b 1) hs
  have hmap_formula (x : L) :
      fLin x = (b.repr x 0) • E₁₁ + (b.repr x 1) • E₁₂ := by
    rw [finTwoBasis_repr b x]
    simp [fLin]
  have hmap_lie (x y : L) : fLin ⁅x, y⁆ = ⁅fLin x, fLin y⁆ := by
    rw [hbracket_formula, hmap_formula x, hmap_formula y]
    -- Compare the matrix entries after expanding both sides in the standard generators.
    ext i j <;> fin_cases i <;> fin_cases j <;>
      simp [Ring.lie_def, Matrix.mul_apply, fLin]
    all_goals ring
  let f : L →ₗ⁅ℝ⁆ gl2 :=
    { toLinearMap := fLin
      map_lie' := by
        intro x y
        exact hmap_lie x y }
  have hf_inj : Function.Injective fLin := by
    intro x y hxy
    have hEq :
        (b.repr x 0) • E₁₁ + (b.repr x 1) • E₁₂ =
          (b.repr y 0) • E₁₁ + (b.repr y 1) • E₁₂ := by
      simpa [hmap_formula x, hmap_formula y] using hxy
    have h0 := congrFun (congrFun hEq 0) 0
    have h1 := congrFun (congrFun hEq 0) 1
    have hre : b.repr x = b.repr y := by
      ext i
      fin_cases i
      · simpa using h0
      · simpa using h1
    exact b.repr.injective hre
  have hrange :
      ((LieHom.range f : LieSubalgebra ℝ gl2) : Submodule ℝ gl2) =
        Submodule.span ℝ (Set.range (![E₁₁, E₁₂] : Fin 2 → gl2)) := by
    simpa [f, fLin] using
      (Module.Basis.constr_range (R := ℝ) (b := b) (S := ℝ)
        (f := (![E₁₁, E₁₂] : Fin 2 → gl2)))
  have hset :
      (LieHom.range f : Set gl2) = gl2_real_two_dimensional_nonabelian_lie_subalgebra := by
    ext z
    change z ∈ (((LieHom.range f : LieSubalgebra ℝ gl2) : Submodule ℝ gl2)) ↔
      z ∈ (gl2_real_two_dimensional_nonabelian_lie_subalgebra : Submodule ℝ gl2)
    rw [hrange, gl2RealTwoDimensionalNonabelian_toSubmodule_eq_spanRange]
  exact ⟨(LieEquiv.ofInjective f hf_inj).trans
    (LieEquiv.ofEq (LieHom.range f) gl2_real_two_dimensional_nonabelian_lie_subalgebra hset)⟩

variable (𝔤 : Type u) [LieRing 𝔤] [LieAlgebra ℝ 𝔤] [FiniteDimensional ℝ 𝔤]

/-- The one-dimensional case of Problem 8-21: every one-dimensional real Lie algebra is
Lie-isomorphic to the one-dimensional Lie subalgebra of `𝔤𝔩(2, ℝ)` generated by
`diag(1, 0)`. -/
theorem one_dimensional_real_lie_algebra_lie_equiv_gl2_model
    (h : Module.finrank ℝ 𝔤 = 1) :
    Nonempty (𝔤 ≃ₗ⁅ℝ⁆ gl2_real_one_dimensional_lie_subalgebra) := by
  -- The one-dimensional case is abelian on both sides, so finrank determines the Lie algebra.
  exact nonemptyLieEquivOfFinrankEqOfIsLieAbelian
    (isLieAbelian_of_finrank_eq_one h)
    (isLieAbelian_of_finrank_eq_one gl2_real_one_dimensional_lie_subalgebra_finrank)
    (h.trans gl2_real_one_dimensional_lie_subalgebra_finrank.symm)

/-- Problem 8-21: every two-dimensional real Lie algebra is Lie-isomorphic to either the diagonal
abelian Lie subalgebra of `𝔤𝔩(2, ℝ)` or the standard nonabelian upper-triangular one. -/
theorem two_dimensional_real_lie_algebra_lie_equiv_gl2_models
    (h : Module.finrank ℝ 𝔤 = 2) :
    Nonempty (𝔤 ≃ₗ⁅ℝ⁆ gl2_real_two_dimensional_abelian_lie_subalgebra) ∨
      Nonempty (𝔤 ≃ₗ⁅ℝ⁆ gl2_real_two_dimensional_nonabelian_lie_subalgebra) := by
  by_cases hab : IsLieAbelian 𝔤
  · -- The abelian two-dimensional case is determined by the shared finrank.
    left
    exact nonemptyLieEquivOfFinrankEqOfIsLieAbelian hab
      gl2_real_two_dimensional_abelian_lie_subalgebra_isLieAbelian
      (h.trans gl2_real_two_dimensional_abelian_lie_subalgebra_finrank.symm)
  · -- Route correction: instead of unfolding an arbitrary 2D bracket, first normalize a basis
    -- so the single nonzero structure constant becomes `1`.
    right
    rcases existsNormalizedBasisOfFinrankEqTwoNotIsLieAbelian h hab with ⟨b, hb⟩
    exact nonemptyLieEquivGl2NonabelianModelOfNormalizedBasis b hb

/-- The distinctness statement for Problem 8-21: the two explicit two-dimensional Lie subalgebras
of `𝔤𝔩(2, ℝ)` above are not Lie-isomorphic, so they give the two distinct isomorphism classes in
dimension `2`. -/
theorem gl2_real_two_dimensional_models_not_lie_equiv :
    ¬ Nonempty
      (gl2_real_two_dimensional_abelian_lie_subalgebra ≃ₗ⁅ℝ⁆
        gl2_real_two_dimensional_nonabelian_lie_subalgebra) := by
  intro h
  rcases h with ⟨e⟩
  -- Abelianity is preserved by Lie equivalence, so the two explicit models cannot coincide.
  have hab : IsLieAbelian gl2_real_two_dimensional_nonabelian_lie_subalgebra :=
    (lie_abelian_iff_equiv_lie_abelian e).mp
      gl2_real_two_dimensional_abelian_lie_subalgebra_isLieAbelian
  exact gl2_real_two_dimensional_nonabelian_lie_subalgebra_not_isLieAbelian hab
