import DoCarmoLib.Riemannian.Exponential.GrowthInduction

/-!
# Properness from geodesic completeness at one point

do Carmo, *Riemannian Geometry*, Ch. 7, Theorem 2.8, a) ⟹ f) ⟹ b) ⟹ c): if `M` is
geodesically complete at a single point `p` — every tangent vector at `p`
generates a continuous global geodesic — then every closed metric ball
centred at `p` is compact; hence every closed bounded subset of `M` is
compact (`M` is a **proper** metric space, statement b)), and in particular
`M` is metrically **complete** (statement c)).

The proof assembles the growth induction with a Bolzano–Weierstrass
argument. Fix `R ≥ 0` and a sequence `(q_k)` in the closed ball
`\bar B_R(p)`; we must extract a subsequence converging inside the ball.

* By `exists_minimizing_geodesic_of_forall_geodesic` (f), the growth
  induction), each `q_k` is the endpoint of a minimizing unit-speed global
  geodesic `γ_k` out of `p`: `γ_k 0 = p`, `γ_k (d(p, q_k)) = q_k`, and the
  initial chart velocity `u_k` of `γ_k` has `g_p`-norm at most `1`.
* The Gram lower bound at `p` (`exists_sq_norm_le_chartMetricInner`) turns
  the `g_p`-bound into a coordinate bound `‖u_k‖ ≤ √c`, so the pairs
  `(u_k, d(p, q_k))` live in the compact set
  `\bar B_{√c}(0) × [0, R] ⊆ E × ℝ` (Heine–Borel in the finite-dimensional
  model space `E`). Extract `φ` strictly monotone with `u_{φ n} → v` and
  `d(p, q_{φ n}) → t₀`.
* Let `γ` be the global geodesic generated by `v` at `p`. The
  **endpoint-continuity hypothesis** `hend` — continuity of geodesics in
  their initial data, supplied by the ODE-flow analysis — gives
  `γ_{φ n} (d(p, q_{φ n})) → γ t₀`, i.e. `q_{φ n} → γ t₀`; the limit lies in
  `\bar B_R(p)` because `dist` is continuous. Sequential compactness of the
  ball follows, and compactness by Bolzano–Weierstrass
  (`IsSeqCompact.isCompact`).
* Properness: an arbitrary closed ball `\bar B_r(x)` is a closed subset of
  `\bar B_{d(p,x)+r}(p)`, hence compact; completeness is
  `complete_of_proper`.

Main declarations: `properSpace_of_forall_geodesic`,
`completeSpace_of_forall_geodesic`.
-/

noncomputable section

open Bundle Manifold Set Filter Metric
open scoped Manifold Topology ContDiff


namespace Riemannian

namespace Exponential

open Riemannian.Geodesic

variable {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E] [InnerProductSpace ℝ E]
  [FiniteDimensional ℝ E] [NeZero (Module.finrank ℝ E)]
variable {H : Type*} [TopologicalSpace H] {I : ModelWithCorners ℝ E H}
variable [I.Boundaryless]

variable {M' : Type*} [MetricSpace M'] [ChartedSpace H M'] [IsManifold I ∞ M']
variable [T2Space (TangentBundle I M')]

omit [InnerProductSpace ℝ E] in
/-- **Math.** **Geodesic completeness at a point implies properness**
(do Carmo Ch. 7, Theorem 2.8, a) ⟹ b)): if every tangent vector at `p`
generates a continuous global geodesic, and geodesics from `p` depend
continuously on their initial data at the endpoint (the hypothesis `hend`),
then `M` is a proper metric space — every closed bounded set is compact.
Bolzano–Weierstrass on the initial data `(u_k, d(p, q_k))` of the minimizing
geodesics from the growth induction (see the module docstring). -/
theorem properSpace_of_forall_geodesic (g : RiemannianMetric I M')
    (hg : g.IsRiemannianDist) (p : M')
    (hp : ∀ v : TangentSpace I p, ∃ γ : ℝ → M', γ 0 = p ∧
      HasDerivAt (fun s => extChartAt I p (γ s)) v 0 ∧ Continuous γ ∧
        IsGeodesic (I := I) g γ)
    (hend : ∀ (γ : ℝ → M') (γs : ℕ → ℝ → M') (v : E) (vs : ℕ → E) (ts : ℕ → ℝ) (t₀ : ℝ),
      IsGeodesic (I := I) g γ → Continuous γ → γ 0 = p →
      (∀ n, IsGeodesic (I := I) g (γs n)) → (∀ n, Continuous (γs n)) →
      (∀ n, γs n 0 = p) →
      HasDerivAt (fun τ => extChartAt I p (γ τ)) v 0 →
      (∀ n, HasDerivAt (fun τ => extChartAt I p (γs n τ)) (vs n) 0) →
      Filter.Tendsto vs Filter.atTop (nhds v) →
      Filter.Tendsto ts Filter.atTop (nhds t₀) →
      Filter.Tendsto (fun n => γs n (ts n)) Filter.atTop (nhds (γ t₀))) :
    ProperSpace M' := by
  classical
  -- the Gram lower bound at `p`: coordinate norm ≤ `√c ·` the `g_p`-norm
  obtain ⟨c, Vc, hc, hVc, -, hgramV⟩ :=
    Geodesic.exists_sq_norm_le_chartMetricInner (I := I) g p
  have hgram0 : ∀ w : E,
      ‖w‖ ^ 2 ≤ c * chartMetricInner (I := I) g p (extChartAt I p p) w w :=
    fun w => hgramV _ (mem_of_mem_nhds hVc) w
  -- Step 1: every closed ball around `p` is compact
  have key : ∀ R : ℝ, IsCompact (Metric.closedBall p R) := by
    intro R
    rcases lt_or_ge R 0 with hR | hR
    · rw [Metric.closedBall_eq_empty.mpr hR]
      exact isCompact_empty
    -- Step 2: sequential compactness
    refine IsSeqCompact.isCompact ?_
    intro qs hqs
    -- Step 3: minimizing geodesics from `p` to each `qs k`
    have hmin := fun k : ℕ =>
      exists_minimizing_geodesic_of_forall_geodesic (I := I) g hg p hp (qs k)
    choose γk hγk0 hγkend hγkc hγkgeo hγku hγklip hγkfacts using hmin
    choose u hu hule using hγku
    -- Step 4: the initial data live in a fixed compact set
    have hunorm : ∀ k, ‖u k‖ ≤ Real.sqrt c := by
      intro k
      have h1 : ‖u k‖ ^ 2 ≤ c := by
        calc ‖u k‖ ^ 2
            ≤ c * chartMetricInner (I := I) g p (extChartAt I p p) (u k) (u k) :=
              hgram0 (u k)
          _ ≤ c * 1 := mul_le_mul_of_nonneg_left (hule k) hc.le
          _ = c := mul_one c
      have h2 := Real.sqrt_le_sqrt h1
      rwa [Real.sqrt_sq (norm_nonneg _)] at h2
    have hmemK : ∀ k : ℕ, (u k, dist p (qs k)) ∈
        Metric.closedBall (0 : E) (Real.sqrt c) ×ˢ Icc (0 : ℝ) R := by
      intro k
      refine ⟨mem_closedBall_zero_iff.mpr (hunorm k), dist_nonneg, ?_⟩
      rw [dist_comm]
      exact Metric.mem_closedBall.mp (hqs k)
    have hK : IsCompact (Metric.closedBall (0 : E) (Real.sqrt c) ×ˢ Icc (0 : ℝ) R) :=
      (isCompact_closedBall _ _).prod isCompact_Icc
    -- Step 5: Bolzano–Weierstrass on the initial data
    obtain ⟨⟨v, t₀⟩, -, φ, hφ, hconv⟩ := hK.tendsto_subseq hmemK
    have hconv_v : Tendsto (fun n => u (φ n)) atTop (𝓝 v) := hconv.fst_nhds
    have hconv_t : Tendsto (fun n => dist p (qs (φ n))) atTop (𝓝 t₀) :=
      hconv.snd_nhds
    -- Step 6: the limit geodesic generated by `v`
    obtain ⟨γlim, hγlim0, hγlimv, hγlimc, hγlimgeo⟩ := hp v
    -- Step 7: endpoint continuity carries `qs (φ n)` to `γlim t₀`
    have hlim := hend γlim (fun n => γk (φ n)) v (fun n => u (φ n))
      (fun n => dist p (qs (φ n))) t₀ hγlimgeo hγlimc hγlim0
      (fun n => hγkgeo (φ n)) (fun n => hγkc (φ n)) (fun n => hγk0 (φ n))
      hγlimv (fun n => hu (φ n)) hconv_v hconv_t
    have hqconv : Tendsto (qs ∘ φ) atTop (𝓝 (γlim t₀)) := by
      have heq : (fun n => γk (φ n) (dist p (qs (φ n)))) = qs ∘ φ :=
        funext fun n => hγkend (φ n)
      rwa [heq] at hlim
    -- Step 8: the limit stays in the ball
    have hmemball : γlim t₀ ∈ Metric.closedBall p R := by
      rw [Metric.mem_closedBall]
      have hdconv : Tendsto (fun n => dist ((qs ∘ φ) n) p) atTop
          (𝓝 (dist (γlim t₀) p)) := hqconv.dist tendsto_const_nhds
      exact le_of_tendsto hdconv (Eventually.of_forall fun n =>
        Metric.mem_closedBall.mp (hqs (φ n)))
    -- Step 9: package for `IsSeqCompact`
    exact ⟨γlim t₀, hmemball, φ, hφ, hqconv⟩
  -- properness: an arbitrary closed ball is a closed subset of a ball around `p`
  refine ⟨fun x r => ?_⟩
  exact (key (dist p x + r)).of_isClosed_subset isClosed_closedBall
    (Metric.closedBall_subset_closedBall' (by rw [dist_comm x p, add_comm]))

omit [InnerProductSpace ℝ E] in
/-- **Math.** **Geodesic completeness at a point implies metric completeness**
(do Carmo Ch. 7, Theorem 2.8, a) ⟹ c)): under the hypotheses of
`properSpace_of_forall_geodesic`, the manifold is a complete metric space —
proper spaces are complete. -/
theorem completeSpace_of_forall_geodesic (g : RiemannianMetric I M')
    (hg : g.IsRiemannianDist) (p : M')
    (hp : ∀ v : TangentSpace I p, ∃ γ : ℝ → M', γ 0 = p ∧
      HasDerivAt (fun s => extChartAt I p (γ s)) v 0 ∧ Continuous γ ∧
        IsGeodesic (I := I) g γ)
    (hend : ∀ (γ : ℝ → M') (γs : ℕ → ℝ → M') (v : E) (vs : ℕ → E) (ts : ℕ → ℝ) (t₀ : ℝ),
      IsGeodesic (I := I) g γ → Continuous γ → γ 0 = p →
      (∀ n, IsGeodesic (I := I) g (γs n)) → (∀ n, Continuous (γs n)) →
      (∀ n, γs n 0 = p) →
      HasDerivAt (fun τ => extChartAt I p (γ τ)) v 0 →
      (∀ n, HasDerivAt (fun τ => extChartAt I p (γs n τ)) (vs n) 0) →
      Filter.Tendsto vs Filter.atTop (nhds v) →
      Filter.Tendsto ts Filter.atTop (nhds t₀) →
      Filter.Tendsto (fun n => γs n (ts n)) Filter.atTop (nhds (γ t₀))) :
    CompleteSpace M' := by
  haveI := properSpace_of_forall_geodesic (I := I) g hg p hp hend
  exact complete_of_proper

end Exponential

end Riemannian
