import Mathlib
import Mathlib.Tactic.Recall

-- `lean_leansearch` was unavailable in this environment, so this recall item was matched
-- against mathlib's canonical `Subgroup.closure` API by local inspection, together with
-- the derived lemmas `Subgroup.subset_closure` and `Subgroup.closure_le`.

/- Definition 7.49-extra-2. If `G` is a group and `S ⊆ G`, the subgroup generated by `S`
is recalled in mathlib as `Subgroup.closure S`. The lemmas `Subgroup.subset_closure` and
`Subgroup.closure_le` express that it is the smallest subgroup containing `S`, equivalently
the intersection of all subgroups containing `S`. -/

section Definition749Extra2

universe u

variable {G : Type u} [Group G]

/-- Source-facing alias for Definition 7.49-extra-2: `subgroupGeneratedBy S` is
`Subgroup.closure S`. -/
abbrev subgroupGeneratedBy (S : Set G) : Subgroup G :=
  Subgroup.closure S

/-- Definition 7.49-extra-2: if `G` is a group and `S ⊆ G`, the subgroup generated by `S`
is the smallest subgroup containing `S`; in mathlib the canonical owner is
`Subgroup.closure S`. -/
recall Subgroup.closure (S : Set G) : Subgroup G

/- The generating subset lies in its subgroup closure. -/
recall Subgroup.subset_closure (S : Set G) : S ⊆ Subgroup.closure S

/- The subgroup closure is the least subgroup containing the generating subset. -/
recall Subgroup.closure_le (K : Subgroup G) {S : Set G} :
  Subgroup.closure S ≤ K ↔ S ⊆ ↑K

/-- `Subgroup.closure S` is the smallest subgroup
containing `S`. It contains the generators, and every subgroup containing `S` also contains
`Subgroup.closure S`. -/
theorem subgroupClosure_isSmallest {S : Set G} :
    S ⊆ Subgroup.closure S ∧
      ∀ K : Subgroup G, S ⊆ (K : Set G) → Subgroup.closure S ≤ K := by
  constructor
  · -- The generated subgroup contains each generator by construction.
    exact Subgroup.subset_closure
  · -- Minimality is exactly the universal property of `Subgroup.closure`.
    intro K hSK
    exact (Subgroup.closure_le (K := K)).2 hSK

/-- A subgroup contains the generated subgroup exactly
when it contains the generators. -/
lemma closure_le_iff_subset {S : Set G} {K : Subgroup G} :
    Subgroup.closure S ≤ K ↔ S ⊆ (K : Set G) := by
  -- This is the textbook "smallest subgroup containing `S`" rewritten in the canonical API.
  exact Subgroup.closure_le (K := K)

/-- The subgroup generated by `S` is the intersection of
all subgroups containing `S`. -/
lemma closure_eq_sInf_subgroups {S : Set G} :
    Subgroup.closure S = sInf {K : Subgroup G | S ⊆ (K : Set G)} := by
  -- We identify the generated subgroup with the intersection by proving the two inclusions
  -- directly in the subgroup lattice.
  refine le_antisymm ?_ ?_
  · -- Every generator lies in every subgroup that contains `S`, hence in their intersection.
    rw [Subgroup.closure_le]
    intro x hx
    exact Subgroup.mem_sInf.2 fun K hK ↦ hK hx
  · -- The intersection is below `Subgroup.closure S` because `Subgroup.closure S` itself
    -- belongs to the family of containing subgroups.
    exact sInf_le (Subgroup.subset_closure : S ⊆ (Subgroup.closure S : Set G))

/-- The generated subgroup contains `S`, is contained in every subgroup containing `S`, and is
the intersection of all subgroups containing `S`. -/
theorem subgroupClosure_characterization {S : Set G} :
    S ⊆ Subgroup.closure S ∧
      (∀ K : Subgroup G, S ⊆ (K : Set G) → Subgroup.closure S ≤ K) ∧
      Subgroup.closure S = sInf {K : Subgroup G | S ⊆ (K : Set G)} := by
  refine ⟨Subgroup.subset_closure, ?_, closure_eq_sInf_subgroups (S := S)⟩
  -- Minimality is the universal property of the subgroup closure.
  intro K hSK
  exact (Subgroup.closure_le (K := K)).2 hSK

end Definition749Extra2
