import Mathlib

-- `lean_leansearch` was unavailable in this environment, so this exercise was matched by local
-- inspection against the canonical owner `Subgroup.closure` together with the bridge
-- `Subgroup.closure_toSubmonoid` and the derived submonoid theorem
-- `Submonoid.closure_eq_image_prod`.

section Exercise713

universe u

variable {G : Type u} [Group G]

/-- Exercise 7.13. The subgroup generated by `S` is exactly the set of finite products of elements
of `S` and their inverses. -/
theorem subgroup_closure_eq_subgroup_word_set (S : Set G) :
    (Subgroup.closure S : Set G) =
      { g | ∃ l : List G, (∀ x ∈ l, x ∈ S ∪ S⁻¹) ∧ l.prod = g } := by
  ext g
  change g ∈ (Subgroup.closure S).toSubmonoid ↔
    g ∈ { g | ∃ l : List G, (∀ x ∈ l, x ∈ S ∪ S⁻¹) ∧ l.prod = g }
  rw [Subgroup.closure_toSubmonoid]
  change g ∈ (Submonoid.closure (S ∪ S⁻¹) : Set G) ↔
    g ∈ { g | ∃ l : List G, (∀ x ∈ l, x ∈ S ∪ S⁻¹) ∧ l.prod = g }
  rw [Submonoid.closure_eq_image_prod, Set.mem_image]
  simp

end Exercise713
