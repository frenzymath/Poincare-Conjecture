import Mathlib.Geometry.Manifold.ContMDiff.Atlas
import Mathlib.Geometry.Manifold.ContMDiff.NormedSpace
import Mathlib.Geometry.Manifold.Instances.Real
import LeeSmoothLib.Ch01.Sec01.Example_1_5
import LeeSmoothLib.Ch01.Sec01_04.Example_1_33
-- Declarations for this item will be appended below by the statement pipeline.

noncomputable section

open Projectivization
open scoped Manifold ContDiff LinearAlgebra.Projectivization

local notation "RVec" m => EuclideanSpace ℝ (Fin (m + 1))

/-- The punctured Euclidean space `ℝ^(n+1) \ {0}` as an open submanifold of `ℝ^(n+1)`. -/
def puncturedEuclidean (n : ℕ) : TopologicalSpace.Opens (RVec n) :=
  ⟨{ x | x ≠ 0 }, isClosed_singleton.isOpen_compl⟩

/-- Membership in `puncturedEuclidean n` is exactly nonvanishing. -/
@[simp] theorem mem_puncturedEuclidean_iff {n : ℕ} {x : RVec n} :
    x ∈ puncturedEuclidean n ↔ x ≠ 0 :=
  Iff.rfl

/-- A map on punctured Euclidean spaces is homogeneous of degree `d` if scaling the input by a
nonzero real scalar scales the output by the `d`th power of that scalar. -/
def IsHomogeneousOfDegree {n k : ℕ} (d : ℤ)
    (P : puncturedEuclidean n → puncturedEuclidean k) : Prop :=
  ∀ (c : ℝ) (hc : c ≠ 0) (x : puncturedEuclidean n),
    (P ⟨c • (x : RVec n),
        show c • (x : RVec n) ≠ 0 from
          smul_ne_zero hc x.2⟩ : RVec k) =
      c ^ d • (P x : RVec k)

/-- A map on punctured Euclidean spaces respects projective classes if scalar multiples have the
same image in projective space. -/
def RespectsProjectiveClasses {n k : ℕ}
    (P : puncturedEuclidean n → puncturedEuclidean k) : Prop :=
  ∀ (a b : puncturedEuclidean n) (t : ℝ), ((a : RVec n) = t • (b : RVec n)) →
    mk ℝ (P a : RVec k) (P a).2 =
      mk ℝ (P b : RVec k) (P b).2

/-- A homogeneous map on punctured Euclidean space respects projective classes. -/
theorem IsHomogeneousOfDegree.respectsProjectiveClasses {n k : ℕ} {d : ℤ}
    {P : puncturedEuclidean n → puncturedEuclidean k}
    (hP : IsHomogeneousOfDegree d P) :
    RespectsProjectiveClasses P := by
  intro a b t hab
  by_cases ht : t = 0
  · -- The zero-scaling case is impossible because `a` is a nonzero representative.
    exfalso
    apply a.2
    rw [hab, ht, zero_smul]
  · -- Route correction: use the source-faithful homogeneity relation, then descend by
    -- `Projectivization.mk_eq_mk_iff'`.
    apply (Projectivization.mk_eq_mk_iff' ℝ _ _ (P a).2 (P b).2).2
    refine ⟨t ^ d, ?_⟩
    have ha :
        (⟨t • (b : RVec n), smul_ne_zero ht b.2⟩ : puncturedEuclidean n) = a :=
      Subtype.ext hab.symm
    have hscale :
        (P ⟨t • (b : RVec n), smul_ne_zero ht b.2⟩ : RVec k) =
          t ^ d • (P b : RVec k) :=
      hP t ht b
    simpa [ha] using hscale.symm

/-- The map on real projective spaces induced by a map on punctured Euclidean spaces that respects
projective classes. -/
def projectivizationMap {n k : ℕ}
    (P : puncturedEuclidean n → puncturedEuclidean k)
    (hP : RespectsProjectiveClasses P) :
    ℝP[n] → ℝP[k] :=
  Projectivization.lift (fun x ↦ mk ℝ (P x : RVec k) (P x).2)
    hP

/-- The induced projective-space map sends the class of `x` to the class of `P x`. -/
@[simp] theorem projectivizationMap_mk {n k : ℕ}
    (P : puncturedEuclidean n → puncturedEuclidean k)
    (hP : RespectsProjectiveClasses P) (x : puncturedEuclidean n) :
    projectivizationMap P hP (mk ℝ (x : RVec n) x.2) =
      mk ℝ (P x : RVec k) (P x).2 := by
  simp [projectivizationMap]

/-- Problem 2-6 (1): if `P : ℝ^(n+1) \ {0} → ℝ^(k+1) \ {0}` is homogeneous of degree `d`, then the
assignment `[x] ↦ [P x]` depends only on the projective class of `x`. -/
theorem homogeneous_map_respects_projective_classes {n k : ℕ}
    (P : puncturedEuclidean n → puncturedEuclidean k) {d : ℤ}
    (hP : IsHomogeneousOfDegree d P)
    {x y : RVec n} (hx : x ≠ 0) (hy : y ≠ 0)
    (hxy : mk ℝ x hx = mk ℝ y hy) :
    mk ℝ (P ⟨x, hx⟩ : RVec k) (P ⟨x, hx⟩).2 =
      mk ℝ (P ⟨y, hy⟩ : RVec k) (P ⟨y, hy⟩).2 := by
  simpa using congrArg (projectivizationMap P hP.respectsProjectiveClasses) hxy

/-- Helper for Problem 2-6: each standard affine chart of `ℝPⁿ` already lies in the smooth
maximal atlas. -/
lemma realProjectiveChart_mem_maximalAtlas (n : ℕ) (i : Fin (n + 1)) :
    realProjectiveChart n i ∈ IsManifold.maximalAtlas (𝓡 n) ∞ (ℝP[n]) := by
  -- The charted-space atlas for `ℝPⁿ` is generated by the standard affine charts.
  have hAtlas : realProjectiveChart n i ∈ atlas (EuclideanSpace ℝ (Fin n)) (ℝP[n]) := by
    change realProjectiveChart n i ∈ { e | ∃ j : Fin (n + 1), e = realProjectiveChart n j }
    exact ⟨i, rfl⟩
  exact IsManifold.subset_maximalAtlas hAtlas

/-- Helper for Problem 2-6: a continuous representative-level map descends to a continuous map on
real projective space. -/
lemma continuous_projectivizationMap {n k : ℕ}
    (P : puncturedEuclidean n → puncturedEuclidean k)
    (hP : RespectsProjectiveClasses P)
    (hCont : Continuous P) :
    Continuous (projectivizationMap P hP) := by
  let q : puncturedEuclidean k → ℝP[k] := Projectivization.mk' ℝ
  have hq : Continuous q := by
    simpa [q, Projectivization.mk'] using
      (continuous_quotient_mk' :
        Continuous
          (@Quotient.mk'
            (puncturedEuclidean k)
            (projectivizationSetoid ℝ (RVec k))))
  have hmk :
      Continuous (fun x : puncturedEuclidean n ↦ mk ℝ (P x : RVec k) (P x).2) := by
    simpa [q, Projectivization.mk'_eq_mk] using hq.comp hCont
  -- Descend the continuous representative-level map through the projectivization quotient.
  simpa [projectivizationMap, Projectivization.lift] using
    hmk.quotient_lift fun a b hab ↦ by
      rcases (show ∃ c : ℝˣ, c • (b : RVec n) = (a : RVec n) from by
        simpa [projectivizationSetoid, MulAction.orbitRel_apply, MulAction.mem_orbit_iff] using hab)
        with ⟨c, hc⟩
      exact hP a b c hc.symm

/-- Helper for Problem 2-6: the standard affine chart lift `u ↦ [u,1]` is smooth as a map into
the punctured Euclidean source. -/
lemma realProjectiveChartInvToPunctured_contMDiff {n : ℕ} (i : Fin (n + 1)) :
    ContMDiff (𝓡 n) (𝓡 (n + 1)) ∞
      (fun u : EuclideanSpace ℝ (Fin n) ↦
        (⟨realProjectiveChartInvVector n i u, realProjectiveChartInvVector_ne_zero n i u⟩ :
          puncturedEuclidean n)) := by
  let f : EuclideanSpace ℝ (Fin n) → puncturedEuclidean n := fun u ↦
    ⟨realProjectiveChartInvVector n i u, realProjectiveChartInvVector_ne_zero n i u⟩
  have hvec :
      ContDiff ℝ (⊤ : WithTop ℕ∞)
        (fun u : EuclideanSpace ℝ (Fin n) ↦ realProjectiveChartInvVector n i u) := by
    -- Each homogeneous coordinate of `[u,1]` is an affine function of `u`.
    refine contDiff_piLp' (p := (2 : ENNReal)) ?_
    intro l
    exact realProjectiveChartInvVector_coordinate_contDiff n i l
  have hval :
      ContMDiff (𝓡 n) (𝓡 (n + 1)) ∞ (Subtype.val ∘ f) := by
    change ContMDiff (𝓡 n) (𝓡 (n + 1)) ∞
      (fun u : EuclideanSpace ℝ (Fin n) ↦ realProjectiveChartInvVector n i u)
    exact hvec.contMDiff.of_le (by simp)
  -- Smoothness into an open subset is equivalent to smoothness after composing with the inclusion.
  exact
    (ContMDiff.subtypeVal_comp_iff (I := 𝓡 n) (I' := 𝓡 (n + 1))
      (U := puncturedEuclidean n) (f := f)).1 hval

/-- Helper for Problem 2-6: in standard affine charts, the induced projective map is given by the
usual quotient of homogeneous coordinates. -/
lemma projectivizationMap_chart_formula {n k : ℕ}
    (P : puncturedEuclidean n → puncturedEuclidean k)
    (hP : RespectsProjectiveClasses P)
    (i : Fin (n + 1)) (j : Fin (k + 1))
    (u : EuclideanSpace ℝ (Fin n)) :
    realProjectiveChart k j (projectivizationMap P hP ((realProjectiveChart n i).symm u)) =
      WithLp.toLp 2
        (fun l ↦
          ((P ⟨realProjectiveChartInvVector n i u,
              realProjectiveChartInvVector_ne_zero n i u⟩ : RVec k) (j.succAbove l)) /
            ((P ⟨realProjectiveChartInvVector n i u,
              realProjectiveChartInvVector_ne_zero n i u⟩ : RVec k) j)) := by
  -- Expand the inverse chart, apply the quotient lift on representatives, and read off the
  -- target chart coordinates.
  let x : puncturedEuclidean n :=
    ⟨realProjectiveChartInvVector n i u, realProjectiveChartInvVector_ne_zero n i u⟩
  have hmk :
      projectivizationMap P hP (mk ℝ (x : RVec n) x.2) =
        mk ℝ (P x : RVec k) (P x).2 :=
    projectivizationMap_mk P hP x
  -- Apply the target chart to the representative-level identity and evaluate that chart.
  simpa [x, realProjectiveChart_symm_apply, realProjectiveChart_mk] using
    congrArg (realProjectiveChart k j) hmk

/-- Helper for Problem 2-6: after precomposing with the standard affine chart lift `u ↦ [u,1]`,
the representative-level map in homogeneous coordinates is Euclidean-smooth. -/
lemma projectivizationMap_chart_representative_contDiff {n k : ℕ}
    (P : puncturedEuclidean n → puncturedEuclidean k)
    (hSmooth : ContMDiff (𝓡 (n + 1)) (𝓡 (k + 1)) ∞ P)
    (i : Fin (n + 1)) :
    ContDiff ℝ ∞
      (fun u : EuclideanSpace ℝ (Fin n) ↦
        (P ⟨realProjectiveChartInvVector n i u,
          realProjectiveChartInvVector_ne_zero n i u⟩ : RVec k)) := by
  let f : EuclideanSpace ℝ (Fin n) → puncturedEuclidean n := fun u ↦
    ⟨realProjectiveChartInvVector n i u, realProjectiveChartInvVector_ne_zero n i u⟩
  have hcomp : ContMDiff (𝓡 n) (𝓡 (k + 1)) ∞ (P ∘ f) := by
    -- Compose the smooth chart lift with the given smooth representative map.
    exact hSmooth.comp (realProjectiveChartInvToPunctured_contMDiff i)
  have hval : ContMDiff (𝓡 n) (𝓡 (k + 1)) ∞ (Subtype.val ∘ P ∘ f) := by
    -- Forgetting the codomain subtype preserves smoothness into the ambient Euclidean space.
    simpa using
      ((ContMDiff.subtypeVal_comp_iff (I := 𝓡 n) (I' := 𝓡 (k + 1))
        (U := puncturedEuclidean k) (f := P ∘ f)).2 hcomp)
  -- On standard Euclidean models, manifold smoothness is ordinary `ContDiff`.
  simpa [f, Function.comp] using hval.contDiff

/-- Helper for Problem 2-6: each affine coordinate quotient in the target chart is smooth within
the model range once the denominator coordinate is nonzero at the base point. -/
lemma projectivizationMap_chart_coordinate_quotient_contDiffWithinAt {n k : ℕ}
    (P : puncturedEuclidean n → puncturedEuclidean k)
    (hSmooth : ContMDiff (𝓡 (n + 1)) (𝓡 (k + 1)) ∞ P)
    (i : Fin (n + 1)) {u0 : EuclideanSpace ℝ (Fin n)} {j : Fin (k + 1)}
    (hj :
      ((P ⟨realProjectiveChartInvVector n i u0,
        realProjectiveChartInvVector_ne_zero n i u0⟩ : RVec k) j) ≠ 0)
    (l : Fin k) :
    ContDiffWithinAt ℝ ∞
      (fun u : EuclideanSpace ℝ (Fin n) ↦
        ((P ⟨realProjectiveChartInvVector n i u,
          realProjectiveChartInvVector_ne_zero n i u⟩ : RVec k) (j.succAbove l)) /
          ((P ⟨realProjectiveChartInvVector n i u,
            realProjectiveChartInvVector_ne_zero n i u⟩ : RVec k) j))
      (Set.range (𝓡 n)) u0 := by
  have hrep := projectivizationMap_chart_representative_contDiff P hSmooth i
  have hnum :
      ContDiff ℝ ∞
        (fun u : EuclideanSpace ℝ (Fin n) ↦
          ((P ⟨realProjectiveChartInvVector n i u,
            realProjectiveChartInvVector_ne_zero n i u⟩ : RVec k) (j.succAbove l))) := by
    -- The numerator is one coordinate of the smooth representative-level map.
    exact (contDiff_piLp_apply (p := (2 : ENNReal)) (i := j.succAbove l)).comp hrep
  have hden :
      ContDiff ℝ ∞
        (fun u : EuclideanSpace ℝ (Fin n) ↦
          ((P ⟨realProjectiveChartInvVector n i u,
            realProjectiveChartInvVector_ne_zero n i u⟩ : RVec k) j)) := by
    -- The denominator is the fixed `j`th coordinate of the same smooth map.
    exact (contDiff_piLp_apply (p := (2 : ENNReal)) (i := j)).comp hrep
  -- Division is smooth within the model range at `u0` because the denominator is nonzero there.
  exact hnum.contDiffWithinAt.div hden.contDiffWithinAt hj

/-- Helper for Problem 2-6: the full Euclidean local model in a fixed pair of projective charts is
smooth within the model range near points where the denominator coordinate does not vanish. -/
lemma projectivizationMap_chart_local_model_contDiffWithinAt {n k : ℕ}
    (P : puncturedEuclidean n → puncturedEuclidean k)
    (hSmooth : ContMDiff (𝓡 (n + 1)) (𝓡 (k + 1)) ∞ P)
    (i : Fin (n + 1)) {u0 : EuclideanSpace ℝ (Fin n)} {j : Fin (k + 1)}
    (hj :
      ((P ⟨realProjectiveChartInvVector n i u0,
        realProjectiveChartInvVector_ne_zero n i u0⟩ : RVec k) j) ≠ 0) :
    ContDiffWithinAt ℝ ∞
      (fun u : EuclideanSpace ℝ (Fin n) ↦
        WithLp.toLp 2
          (fun l ↦
            ((P ⟨realProjectiveChartInvVector n i u,
              realProjectiveChartInvVector_ne_zero n i u⟩ : RVec k) (j.succAbove l)) /
              ((P ⟨realProjectiveChartInvVector n i u,
                realProjectiveChartInvVector_ne_zero n i u⟩ : RVec k) j)))
      (Set.range (𝓡 n)) u0 := by
  -- Assemble the coordinatewise quotient smoothness into a smooth `WithLp`-valued map.
  refine contDiffWithinAt_piLp' (p := (2 : ENNReal)) ?_
  intro l
  exact projectivizationMap_chart_coordinate_quotient_contDiffWithinAt P hSmooth i hj l

/-- Helper for Problem 2-6: on the neighborhood where the source chart inverse is defined, the
conjugated projective map agrees with the explicit chart formula. -/
lemma projectivizationMap_chart_expression_eventuallyEq {n k : ℕ}
    (P : puncturedEuclidean n → puncturedEuclidean k)
    (hP : RespectsProjectiveClasses P)
    {x : ℝP[n]} (i : Fin (n + 1)) (j : Fin (k + 1))
    (hx : x ∈ realProjectiveChartDomain n i) :
    let e := realProjectiveChart n i
    let e' := realProjectiveChart k j
    let x' : EuclideanSpace ℝ (Fin n) := (e.extend (𝓡 n)) x
    ((e'.extend (𝓡 k)) ∘ projectivizationMap P hP ∘ (e.extend (𝓡 n)).symm)
      =ᶠ[nhdsWithin x' (Set.range (𝓡 n))]
        (fun u : EuclideanSpace ℝ (Fin n) ↦
          WithLp.toLp 2
            (fun l ↦
              ((P ⟨realProjectiveChartInvVector n i u,
                realProjectiveChartInvVector_ne_zero n i u⟩ : RVec k) (j.succAbove l)) /
                ((P ⟨realProjectiveChartInvVector n i u,
                  realProjectiveChartInvVector_ne_zero n i u⟩ : RVec k) j))) := by
  let e := realProjectiveChart n i
  let e' := realProjectiveChart k j
  let x' : EuclideanSpace ℝ (Fin n) := (e.extend (𝓡 n)) x
  have hxsource : x ∈ e.source := by
    simpa [e] using hx
  have htarget_mem : (e.extend (𝓡 n)).target ∈ nhdsWithin x' (Set.range (𝓡 n)) := by
    -- The extended source-chart target is the canonical neighborhood where the chart formula holds.
    simpa [e, x'] using (e.extend_target_mem_nhdsWithin (I := 𝓡 n) hxsource)
  -- On the extended source-chart target, the conjugated map is exactly the quotient formula.
  refine Filter.eventuallyEq_of_mem htarget_mem ?_
  intro u hu
  simpa [e, e', Function.comp, OpenPartialHomeomorph.extend_coe_symm,
    OpenPartialHomeomorph.extend_coe] using projectivizationMap_chart_formula P hP i j u

/-- Helper for Problem 2-6: after choosing source and target standard charts containing a point
and its image, the descended projective map is smooth at that point. -/
lemma contMDiffAt_projectivizationMap_of_chart_pair {n k : ℕ}
    (P : puncturedEuclidean n → puncturedEuclidean k)
    (hP : RespectsProjectiveClasses P)
    (hSmooth : ContMDiff (𝓡 (n + 1)) (𝓡 (k + 1)) ∞ P)
    {x : ℝP[n]} {i : Fin (n + 1)} {j : Fin (k + 1)}
    (hx : x ∈ realProjectiveChartDomain n i)
    (hy : projectivizationMap P hP x ∈ realProjectiveChartDomain k j) :
    ContMDiffAt (𝓡 n) (𝓡 k) ∞ (projectivizationMap P hP) x := by
  let e := realProjectiveChart n i
  let e' := realProjectiveChart k j
  let x' : EuclideanSpace ℝ (Fin n) := (e.extend (𝓡 n)) x
  have he : e ∈ IsManifold.maximalAtlas (𝓡 n) ∞ (ℝP[n]) :=
    realProjectiveChart_mem_maximalAtlas n i
  have he' : e' ∈ IsManifold.maximalAtlas (𝓡 k) ∞ (ℝP[k]) :=
    realProjectiveChart_mem_maximalAtlas k j
  have hxsource : x ∈ e.source := by
    simpa [e] using hx
  have hysource : projectivizationMap P hP x ∈ e'.source := by
    simpa [e'] using hy
  -- Route correction: reduce manifold smoothness to one fixed chart pair, then replace the chart
  -- conjugate by the explicit quotient local model from homogeneous coordinates.
  rw [ContMDiffAt, contMDiffWithinAt_iff_of_mem_maximalAtlas
    (I := 𝓡 n) (I' := 𝓡 k) (e := e) (e' := e') he he' hxsource hysource,
    continuousWithinAt_univ, Set.preimage_univ, Set.univ_inter]
  refine ⟨(continuous_projectivizationMap P hP hSmooth.continuous).continuousAt, ?_⟩
  have hx_eq : (realProjectiveChart n i).symm x' = x := by
    -- The source chart inverse recovers `x` from its own affine coordinates.
    change (realProjectiveChart n i).symm (((realProjectiveChart n i).extend (𝓡 n)) x) = x
    simpa [OpenPartialHomeomorph.extend_coe] using
      (OpenPartialHomeomorph.left_inv (realProjectiveChart n i) hx)
  have hy_chart :
      projectivizationMap P hP ((realProjectiveChart n i).symm x') ∈
        realProjectiveChartDomain k j := by
    simpa [hx_eq] using hy
  let x0 : puncturedEuclidean n :=
    ⟨realProjectiveChartInvVector n i x', realProjectiveChartInvVector_ne_zero n i x'⟩
  have hden :
      ((P x0 : RVec k) j) ≠ 0 := by
    -- Membership of the image in the target chart is exactly the nonvanishing denominator
    -- condition in homogeneous coordinates.
    simpa [x0, realProjectiveChart_symm_apply] using
      (realProjectiveChartDomain_mk k j (P x0 : RVec k) (P x0).2).1 <| by
        simpa [x0] using
          (show projectivizationMap P hP (mk ℝ (x0 : RVec n) x0.2) ∈
              realProjectiveChartDomain k j from by
            simpa [x0, realProjectiveChart_symm_apply] using hy_chart)
  have hmodel :
      ContDiffWithinAt ℝ ∞
        (fun u : EuclideanSpace ℝ (Fin n) ↦
          WithLp.toLp 2
            (fun l ↦
                ((P ⟨realProjectiveChartInvVector n i u,
                  realProjectiveChartInvVector_ne_zero n i u⟩ : RVec k) (j.succAbove l)) /
                  ((P ⟨realProjectiveChartInvVector n i u,
                    realProjectiveChartInvVector_ne_zero n i u⟩ : RVec k) j)))
        (Set.range (𝓡 n)) x' := by
    -- The Euclidean quotient model is smooth once the denominator coordinate is nonzero at `x'`.
    simpa [x0] using projectivizationMap_chart_local_model_contDiffWithinAt P hSmooth i hden
  have hEq :
      ((e'.extend (𝓡 k)) ∘ projectivizationMap P hP ∘ (e.extend (𝓡 n)).symm)
        =ᶠ[nhdsWithin x' (Set.range (𝓡 n))]
          (fun u : EuclideanSpace ℝ (Fin n) ↦
            WithLp.toLp 2
              (fun l ↦
                ((P ⟨realProjectiveChartInvVector n i u,
                  realProjectiveChartInvVector_ne_zero n i u⟩ : RVec k) (j.succAbove l)) /
                  ((P ⟨realProjectiveChartInvVector n i u,
                    realProjectiveChartInvVector_ne_zero n i u⟩ : RVec k) j))) := by
    -- The chart formula is valid on the neighborhood cut out by the extended source-chart target.
    simpa [e, e', x'] using projectivizationMap_chart_expression_eventuallyEq P hP i j hx
  have hx'_target : x' ∈ (e.extend (𝓡 n)).target :=
    (e.extend (𝓡 n)).map_source <| by
      simpa [e, OpenPartialHomeomorph.extend_source] using hxsource
  have hx'_range : x' ∈ Set.range (𝓡 n) := e.extend_target_subset_range hx'_target
  -- Replace the chart conjugate by the smooth Euclidean local model.
  exact hmodel.congr_of_eventuallyEq hEq <| hEq.eq_of_nhdsWithin hx'_range

/-- A smooth map on punctured Euclidean spaces that respects projective classes induces a smooth
map on real projective spaces. -/
theorem contMDiff_projectivizationMap {n k : ℕ}
    (P : puncturedEuclidean n → puncturedEuclidean k)
    (hP : RespectsProjectiveClasses P)
    (hSmooth : ContMDiff (𝓡 (n + 1)) (𝓡 (k + 1)) ∞ P) :
    ContMDiff (𝓡 n) (𝓡 k) ∞ (projectivizationMap P hP) := by
  intro x
  -- Choose standard affine charts around the source point and its image.
  obtain ⟨i, hx⟩ := real_projective_space_has_standard_chart n x
  obtain ⟨j, hy⟩ := real_projective_space_has_standard_chart k (projectivizationMap P hP x)
  exact contMDiffAt_projectivizationMap_of_chart_pair P hP hSmooth hx hy

/-- Problem 2-6 (2): if `P : ℝ^(n+1) \ {0} → ℝ^(k+1) \ {0}` is smooth and homogeneous of degree
`d`, then the induced map `ℝPⁿ → ℝPᵏ` is smooth. -/
theorem contMDiff_homogeneousProjectivizationMap {n k : ℕ}
    (P : puncturedEuclidean n → puncturedEuclidean k) {d : ℤ}
    (hP : IsHomogeneousOfDegree d P)
    (hSmooth : ContMDiff (𝓡 (n + 1)) (𝓡 (k + 1)) ∞ P) :
    ContMDiff (𝓡 n) (𝓡 k) ∞ (projectivizationMap P hP.respectsProjectiveClasses) := by
  simpa using contMDiff_projectivizationMap P hP.respectsProjectiveClasses hSmooth
