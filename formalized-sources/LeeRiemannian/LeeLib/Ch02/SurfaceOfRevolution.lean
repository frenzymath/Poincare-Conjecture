/-
Chapter 2, "Riemannian Metrics", §3 "Methods for Constructing Riemannian
Metrics": surfaces of revolution.

Lee's Example 2.20.  Let `C` be a curve in the half-plane `{(r,z) : r > 0}` with
a local parametrization `γ(t) = (a(t), b(t))`.  The surface of revolution `S_C`
it generates has the local parametrization
`X(t, θ) = (a(t) cos θ, a(t) sin θ, b(t))`, and the metric induced on it by the
Euclidean metric of `ℝ³` is

  `X^* ḡ = (a'(t)² + b'(t)²) dt² + a(t)² dθ²`.

In particular, when the generating curve is unit speed (`a'² + b'² ≡ 1`) this is
`dt² + a(t)² dθ²`, and the three worked instances Lee lists follow by specialising
`(a, b)`:

* the sphere `S²` from the semicircle `γ(φ) = (sin φ, cos φ)`, metric
  `dφ² + sin²φ dθ²` (`surfaceOfRevolutionMetric_sphere`);
* the cylinder from the vertical line `γ(t) = (1, t)`, metric `dt² + dθ²`
  (`surfaceOfRevolutionMetric_cylinder`);
* the torus of revolution from `γ(t) = (2 + cos t, sin t)`, metric
  `dt² + (2 + cos t)² dθ²` (`surfaceOfRevolutionMetric_torus`).

Following Lee's §2.3, the induced metric is the pullback `X^* ḡ` of the Euclidean
metric along the parametrization `X`, so this is `pullbackForm` (a form, because a
single parametrization only covers part of the surface) of `euclideanMetric` on
`ℝ³ = EuclideanSpace ℝ (Fin 3)`.  All the content is the Jacobian computation and
the cancellation `cos²θ + sin²θ = 1` of the `dt dθ` cross terms.

Provenance: this is the same computation as Petersen's Example 1.4.4
(`PetersenLib/Ch01/SurfaceOfRevolution.lean`); the proof is ported to LeeLib's
`pullbackForm` / `euclideanMetric` API.
-/
import LeeLib.Ch02.PullbackMetric
import Mathlib.Analysis.SpecialFunctions.Trigonometric.Deriv

set_option linter.unnecessarySeqFocus false

noncomputable section

open Real Bundle Manifold
open scoped ContDiff Manifold Topology RealInnerProductSpace

namespace LeeLib.Ch02

/-- **The parametrization of a surface of revolution** (Lee, Example 2.20):
`X(t, θ) = (a(t) cos θ, a(t) sin θ, b(t))`, the surface generated by revolving the
profile curve `γ(t) = (a(t), b(t))` in the `rz`-half-plane about the `z`-axis. -/
def surfaceOfRevolutionMap (a b : ℝ → ℝ) (p : ℝ × ℝ) : EuclideanSpace ℝ (Fin 3) :=
  !₂[a p.1 * Real.cos p.2, a p.1 * Real.sin p.2, b p.1]

/-- **The Jacobian of the surface-of-revolution parametrization**:
`dx = a' cos θ dt − a sin θ dθ`, `dy = a' sin θ dt + a cos θ dθ`, `dz = b' dt`. -/
def surfaceOfRevolutionJacobian (a b : ℝ → ℝ) (p : ℝ × ℝ) :
    (ℝ × ℝ) →L[ℝ] EuclideanSpace ℝ (Fin 3) :=
  ((PiLp.continuousLinearEquiv 2 ℝ (fun _ : Fin 3 => ℝ)).symm :
      (Fin 3 → ℝ) →L[ℝ] EuclideanSpace ℝ (Fin 3)).comp
    (ContinuousLinearMap.pi
      ![(deriv a p.1 * Real.cos p.2) • ContinuousLinearMap.fst ℝ ℝ ℝ +
          (-(a p.1 * Real.sin p.2)) • ContinuousLinearMap.snd ℝ ℝ ℝ,
        (deriv a p.1 * Real.sin p.2) • ContinuousLinearMap.fst ℝ ℝ ℝ +
          (a p.1 * Real.cos p.2) • ContinuousLinearMap.snd ℝ ℝ ℝ,
        (deriv b p.1) • ContinuousLinearMap.fst ℝ ℝ ℝ])

theorem hasFDerivAt_surfaceOfRevolutionMap {a b : ℝ → ℝ}
    (ha : Differentiable ℝ a) (hb : Differentiable ℝ b) (p : ℝ × ℝ) :
    HasFDerivAt (surfaceOfRevolutionMap a b)
      (surfaceOfRevolutionJacobian a b p) p := by
  have hafst : HasFDerivAt (fun q : ℝ × ℝ => a q.1)
      ((deriv a p.1) • ContinuousLinearMap.fst ℝ ℝ ℝ) p :=
    ((ha p.1).hasDerivAt).comp_hasFDerivAt p hasFDerivAt_fst
  have hbfst : HasFDerivAt (fun q : ℝ × ℝ => b q.1)
      ((deriv b p.1) • ContinuousLinearMap.fst ℝ ℝ ℝ) p :=
    ((hb p.1).hasDerivAt).comp_hasFDerivAt p hasFDerivAt_fst
  have hΦ : HasFDerivAt
      (fun q : ℝ × ℝ =>
        (![a q.1 * Real.cos q.2, a q.1 * Real.sin q.2, b q.1] : Fin 3 → ℝ))
      (ContinuousLinearMap.pi
        ![(deriv a p.1 * Real.cos p.2) • ContinuousLinearMap.fst ℝ ℝ ℝ +
            (-(a p.1 * Real.sin p.2)) • ContinuousLinearMap.snd ℝ ℝ ℝ,
          (deriv a p.1 * Real.sin p.2) • ContinuousLinearMap.fst ℝ ℝ ℝ +
            (a p.1 * Real.cos p.2) • ContinuousLinearMap.snd ℝ ℝ ℝ,
          (deriv b p.1) • ContinuousLinearMap.fst ℝ ℝ ℝ]) p := by
    rw [hasFDerivAt_pi']
    rw [Fin.forall_fin_succ, Fin.forall_fin_two]
    refine ⟨?_, ?_, ?_⟩
    · have hcos : HasFDerivAt (fun q : ℝ × ℝ => Real.cos q.2)
          ((-Real.sin p.2) • ContinuousLinearMap.snd ℝ ℝ ℝ) p :=
        (Real.hasDerivAt_cos p.2).comp_hasFDerivAt p hasFDerivAt_snd
      have h := hafst.mul hcos
      refine h.congr_fderiv ?_
      ext <;> simp [ContinuousLinearMap.proj_pi] <;> ring
    · have hsin : HasFDerivAt (fun q : ℝ × ℝ => Real.sin q.2)
          ((Real.cos p.2) • ContinuousLinearMap.snd ℝ ℝ ℝ) p :=
        (Real.hasDerivAt_sin p.2).comp_hasFDerivAt p hasFDerivAt_snd
      have h := hafst.mul hsin
      refine h.congr_fderiv ?_
      ext <;> simp [ContinuousLinearMap.proj_pi] <;> ring
    · refine hbfst.congr_fderiv ?_
      ext <;> simp [ContinuousLinearMap.proj_pi]
  exact (((PiLp.continuousLinearEquiv 2 ℝ (fun _ : Fin 3 => ℝ)).symm :
    (Fin 3 → ℝ) →L[ℝ] EuclideanSpace ℝ (Fin 3)).hasFDerivAt).comp p hΦ

/-- **Lee's Example 2.20: the metric of a surface of revolution.**  The metric
induced from `dx² + dy² + dz²` by the parametrization
`X(t, θ) = (a(t) cos θ, a(t) sin θ, b(t))` is `(a'² + b'²) dt² + a² dθ²`: the
`dt dθ` cross terms cancel because `cos²θ + sin²θ = 1`. -/
theorem surfaceOfRevolutionMetric {a b : ℝ → ℝ}
    (ha : Differentiable ℝ a) (hb : Differentiable ℝ b) (p : ℝ × ℝ)
    (u v : TangentSpace 𝓘(ℝ, ℝ × ℝ) p) :
    pullbackForm (euclideanMetric (EuclideanSpace ℝ (Fin 3)))
        (surfaceOfRevolutionMap a b) p u v =
      ((deriv a p.1) ^ 2 + (deriv b p.1) ^ 2) * (u.1 * v.1) +
        (a p.1) ^ 2 * (u.2 * v.2) := by
  rw [pullbackForm_apply, euclideanMetric_inner]
  have hmf : mfderiv 𝓘(ℝ, ℝ × ℝ) 𝓘(ℝ, EuclideanSpace ℝ (Fin 3))
      (surfaceOfRevolutionMap a b) p = surfaceOfRevolutionJacobian a b p := by
    rw [mfderiv_eq_fderiv]
    exact (hasFDerivAt_surfaceOfRevolutionMap ha hb p).fderiv
  rw [hmf]
  show @inner ℝ _ _ (surfaceOfRevolutionJacobian a b p u)
    (surfaceOfRevolutionJacobian a b p v) = _
  simp only [surfaceOfRevolutionJacobian, ContinuousLinearMap.coe_comp',
    Function.comp_apply, ContinuousLinearEquiv.coe_coe, PiLp.inner_apply,
    Fin.sum_univ_three]
  simp only [PiLp.continuousLinearEquiv_symm_apply, ContinuousLinearMap.pi_apply,
    Matrix.cons_val_zero, Matrix.cons_val_one, Matrix.cons_val_two,
    Matrix.head_cons, Matrix.tail_cons,
    ContinuousLinearMap.add_apply, ContinuousLinearMap.smul_apply,
    ContinuousLinearMap.coe_fst', ContinuousLinearMap.coe_snd', smul_eq_mul]
  have hinner : ∀ x y : ℝ, (inner ℝ x y : ℝ) = y * x := fun _ _ => rfl
  simp only [hinner]
  have hpyth := Real.sin_sq_add_cos_sq p.2
  linear_combination
    ((deriv a p.1) ^ 2 * (u.1 * v.1) + (a p.1) ^ 2 * (u.2 * v.2)) * hpyth

/-- **Lee's Example 2.20, unit-speed case.**  If the generating curve is
parametrized by arc length (`a'² + b'² ≡ 1`), the induced metric is
`dt² + a² dθ²`. -/
theorem surfaceOfRevolutionMetric_unitSpeed {a b : ℝ → ℝ}
    (ha : Differentiable ℝ a) (hb : Differentiable ℝ b)
    (harc : ∀ t, (deriv a t) ^ 2 + (deriv b t) ^ 2 = 1) (p : ℝ × ℝ)
    (u v : TangentSpace 𝓘(ℝ, ℝ × ℝ) p) :
    pullbackForm (euclideanMetric (EuclideanSpace ℝ (Fin 3)))
        (surfaceOfRevolutionMap a b) p u v =
      u.1 * v.1 + (a p.1) ^ 2 * (u.2 * v.2) := by
  rw [surfaceOfRevolutionMetric ha hb p u v, harc p.1, one_mul]

/-- **Lee's Example 2.20, the sphere `S²`.**  The generating semicircle
`γ(φ) = (sin φ, cos φ)` is unit speed, and the surface of revolution it sweeps out
is the unit sphere (the *spherical coordinate parametrization*); the induced
metric is `dφ² + sin²φ dθ²`. -/
theorem surfaceOfRevolutionMetric_sphere (p : ℝ × ℝ)
    (u v : TangentSpace 𝓘(ℝ, ℝ × ℝ) p) :
    pullbackForm (euclideanMetric (EuclideanSpace ℝ (Fin 3)))
        (surfaceOfRevolutionMap Real.sin Real.cos) p u v =
      u.1 * v.1 + (Real.sin p.1) ^ 2 * (u.2 * v.2) := by
  refine surfaceOfRevolutionMetric_unitSpeed Real.differentiable_sin
    Real.differentiable_cos (fun t => ?_) p u v
  rw [Real.deriv_sin, Real.deriv_cos']
  simp only [neg_sq]
  exact Real.cos_sq_add_sin_sq t

/-- **Lee's Example 2.20, the cylinder.**  The vertical generating line
`γ(t) = (1, t)` is unit speed and sweeps out the unit cylinder; the induced metric
is the flat `dt² + dθ²`, so this parametrization is an isometric immersion. -/
theorem surfaceOfRevolutionMetric_cylinder (p : ℝ × ℝ)
    (u v : TangentSpace 𝓘(ℝ, ℝ × ℝ) p) :
    pullbackForm (euclideanMetric (EuclideanSpace ℝ (Fin 3)))
        (surfaceOfRevolutionMap (fun _ => 1) id) p u v =
      u.1 * v.1 + u.2 * v.2 := by
  have h := surfaceOfRevolutionMetric_unitSpeed (a := fun _ : ℝ => 1) (b := id)
    (differentiable_const 1) differentiable_id
    (fun t => by rw [deriv_const', deriv_id']; norm_num) p u v
  simpa using h

/-- **Lee's Example 2.20, the torus of revolution.**  The generating circle
`γ(t) = (2 + cos t, sin t)` (of radius `1` centred at `r = 2`) is unit speed; the
induced metric on the resulting torus of revolution is `dt² + (2 + cos t)² dθ²`. -/
theorem surfaceOfRevolutionMetric_torus (p : ℝ × ℝ)
    (u v : TangentSpace 𝓘(ℝ, ℝ × ℝ) p) :
    pullbackForm (euclideanMetric (EuclideanSpace ℝ (Fin 3)))
        (surfaceOfRevolutionMap (fun t => 2 + Real.cos t) Real.sin) p u v =
      u.1 * v.1 + (2 + Real.cos p.1) ^ 2 * (u.2 * v.2) := by
  refine surfaceOfRevolutionMetric_unitSpeed
    (by fun_prop) Real.differentiable_sin (fun t => ?_) p u v
  rw [deriv_const_add, Real.deriv_cos', Real.deriv_sin]
  simp only [neg_sq]
  exact Real.sin_sq_add_cos_sq t

end LeeLib.Ch02
