import Mathlib.Geometry.Manifold.GroupLieAlgebra
import Mathlib.Geometry.Manifold.IntegralCurve.ExistUnique

/-!
# One-parameter subgroups of an abstract Lie group (Petersen §2.1.4, foundations)

Petersen defines the Lie-group exponential map — and, through it, the `Ad`/`ad`
correspondence used in Exercise 1.6.24 (3) — via **flows of left-invariant
vector fields**: the one-parameter subgroup `t ↦ φ(t)` generated by `U ∈ 𝔤`
is the integral curve through `1` of the left-invariant field
`mulInvariantVectorField U`.  Mathlib has the general left-invariant field
(`Mathlib.Geometry.Manifold.GroupLieAlgebra`) and a local existence theorem for
integral curves (`Mathlib.Geometry.Manifold.IntegralCurve.ExistUnique`) but does
**not** assemble the two into one-parameter subgroups, nor into the `exp`/`Ad`–`ad`
correspondence.  This file supplies that missing first layer for an abstract Lie
group `G` (modelled on a boundaryless model with complete model space):

* `mulInvariantVectorField_one` — the left-invariant field of `v ∈ 𝔤` takes the
  value `v` at the identity (`X_v(1) = v`).
* `exists_oneParameterSubgroup` — the integral curve of `mulInvariantVectorField U`
  through `1` exists locally: a curve `φ` with `φ 0 = 1` tangent to the invariant
  field near `0`.
* `oneParameterSubgroup_hasMFDerivAt_zero` — its initial velocity is `U`:
  `Dφ|₀ = (t ↦ t · U)`.

These are the objects Petersen §2.1.4 differentiates to obtain
`ad_U = d/dt|₀ Ad_{φ(t)}`.  The remaining steps toward Exercise 1.6.24 (3)
(`PetersenLib.exercise1_6_24_ad_skew`) — the one-parameter *subgroup* law
`φ(s + t) = φ(s)·φ(t)` (from uniqueness of integral curves) and the flow-bracket
identity `d/dt|₀ Ad_{φ(t)} = ad_U` — are recorded in the module docstring of that
exercise as the genuinely external §2.1.4 gap.

Reference: Petersen, *Riemannian Geometry* (3rd ed.), §2.1.4.
-/

open Bundle Set Function VectorField
open scoped Manifold ContDiff Topology

noncomputable section

namespace PetersenLib

variable {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E]
  {H : Type*} [TopologicalSpace H] {I : ModelWithCorners ℝ E H}
  {G : Type*} [Group G] [TopologicalSpace G] [ChartedSpace H G]
  [IsManifold I ∞ G] [LieGroup I ∞ G]

omit [IsManifold I ∞ G] [LieGroup I ∞ G] in
/-- **Math.** The left-invariant vector field `X_v = mulInvariantVectorField v`
generated by `v ∈ 𝔤 = T_1 G` takes the value `v` at the identity:
`X_v(1) = d(L_1)_1 v = d(id)_1 v = v`. -/
@[simp]
theorem mulInvariantVectorField_one (v : GroupLieAlgebra I G) :
    mulInvariantVectorField v (1 : G) = v := by
  rw [mulInvariantVectorField, show (fun x : G => (1 : G) * x) = id from by funext x; simp,
    mfderiv_id]
  rfl

omit [IsManifold I ∞ G] in
/-- **Math.** (Petersen §2.1.4, foundations.) *Existence of the one-parameter
subgroup generated by `U`.* On a boundaryless abstract Lie group `G` with
complete model space, the left-invariant vector field `X_U` has a local integral
curve through the identity: there is `φ : ℝ → G` with `φ 0 = 1` that is tangent
to `X_U = mulInvariantVectorField U` on a neighbourhood of `0`.

This is Picard–Lindelöf (`exists_isMIntegralCurveAt_of_contMDiffAt_boundaryless`)
applied to the smooth invariant field `X_U` (`contMDiff_mulInvariantVectorField`).
The curve `φ` is Petersen's `t ↦ exp(tU)` in the abstract setting. -/
theorem exists_oneParameterSubgroup [CompleteSpace E] [BoundarylessManifold I G]
    (U : GroupLieAlgebra I G) :
    ∃ φ : ℝ → G, φ 0 = 1 ∧ IsMIntegralCurveAt φ (mulInvariantVectorField U) 0 := by
  haveI : LieGroup I (minSmoothness ℝ 3) G := by
    rw [minSmoothness_of_isRCLikeNormedField]; infer_instance
  refine exists_isMIntegralCurveAt_of_contMDiffAt_boundaryless
    (v := mulInvariantVectorField U) (t₀ := 0) (x₀ := (1 : G)) ?_
  exact (contMDiff_mulInvariantVectorField U).contMDiffAt.of_le (one_le_two.trans le_minSmoothness)

omit [IsManifold I ∞ G] [LieGroup I ∞ G] in
/-- **Math.** (Petersen §2.1.4, foundations.) *The one-parameter subgroup has
initial velocity `U`.* If `φ` is the integral curve of the left-invariant field
`X_U` through the identity (`φ 0 = 1`), then its manifold derivative at `0` is the
map `t ↦ t · U`, i.e. `φ'(0) = U ∈ 𝔤`. -/
theorem oneParameterSubgroup_hasMFDerivAt_zero {φ : ℝ → G} {U : GroupLieAlgebra I G}
    (hφ0 : φ 0 = 1) (hφ : IsMIntegralCurveAt φ (mulInvariantVectorField U) 0) :
    HasMFDerivAt 𝓘(ℝ, ℝ) I φ 0
      ((1 : ℝ →L[ℝ] ℝ).smulRight (U : TangentSpace I (1 : G))) := by
  have h := hφ.hasMFDerivAt
  rw [hφ0, mulInvariantVectorField_one] at h
  exact h

omit [IsManifold I ∞ G] in
/-- **Math.** *Left-invariance of the invariant field, differential form.* The
value of the left-invariant field `X_U` at `g·h` is the image of its value at
`h` under `d(L_g)_h`: `d(L_g)_h (X_U(h)) = X_U(g·h)`. This is the chain rule for
the differential of `L_g ∘ L_h = L_{g·h}` applied to `U ∈ 𝔤`. -/
theorem mfderiv_mul_left_mulInvariantVectorField (g h : G) (U : GroupLieAlgebra I G) :
    mfderiv I I (fun x => g * x) h (mulInvariantVectorField U h)
      = mulInvariantVectorField U (g * h) := by
  have hcomp : (fun x : G => (g * h) * x) = (fun x : G => g * x) ∘ (fun x : G => h * x) := by
    funext x; simp [mul_assoc]
  show mfderiv I I (fun x => g * x) h (mfderiv I I (fun x => h * x) 1 U)
      = mfderiv I I (fun x => (g * h) * x) 1 U
  rw [hcomp, mfderiv_comp (1 : G) ((contMDiff_mul_left (n := ∞)).mdifferentiableAt (by simp))
    ((contMDiff_mul_left (n := ∞)).mdifferentiableAt (by simp))]
  rw [mul_one]; rfl

omit [IsManifold I ∞ G] in
/-- **Math.** *Left translations carry integral curves of `X_U` to integral
curves of `X_U`.* If `φ` integrates the left-invariant field `X_U` near `t₀`,
then so does `t ↦ g · φ(t)`.  This is left-invariance of `X_U` at the level of
flows, and it is the key step in the one-parameter *subgroup* law
`φ(s + t) = φ(s)·φ(t)`. -/
theorem isMIntegralCurveAt_mul_left {φ : ℝ → G} {U : GroupLieAlgebra I G}
    (g : G) {t₀ : ℝ} (hφ : IsMIntegralCurveAt φ (mulInvariantVectorField U) t₀) :
    IsMIntegralCurveAt (fun t => g * φ t) (mulInvariantVectorField U) t₀ := by
  filter_upwards [hφ] with t ht
  have hg : HasMFDerivAt I I (fun x => g * x) (φ t)
      (mfderiv I I (fun x => g * x) (φ t)) :=
    ((contMDiff_mul_left (n := ∞)).mdifferentiableAt (by simp)).hasMFDerivAt
  have hcomp := hg.comp t ht
  have hvel : (mfderiv I I (fun x => g * x) (φ t)).comp
        ((1 : ℝ →L[ℝ] ℝ).smulRight (mulInvariantVectorField U (φ t)))
      = (1 : ℝ →L[ℝ] ℝ).smulRight (mulInvariantVectorField U (g * φ t)) := by
    apply ContinuousLinearMap.ext
    intro s
    simp only [ContinuousLinearMap.comp_apply, ContinuousLinearMap.smulRight_apply,
      ContinuousLinearMap.one_apply, map_smul]
    rw [mfderiv_mul_left_mulInvariantVectorField]
  rw [← hvel]
  exact hcomp

omit [IsManifold I ∞ G] in
/-- **Math.** (Petersen §2.1.4, foundations.) *Local one-parameter subgroup law.*
If `φ` is the integral curve of the left-invariant field `X_U` through the
identity (`φ 0 = 1`) — both at `0` and at `s` (the latter holds automatically for
`s` in the interval of definition around `0`) — then the one-parameter subgroup
law `φ(s + t) = φ(s)·φ(t)` holds for `t` near `0`.

Both `t ↦ φ(s + t)` (a time shift of `φ`, `IsMIntegralCurveAt.comp_add`) and
`t ↦ φ(s)·φ(t)` (a left translate of `φ`, `isMIntegralCurveAt_mul_left`) are
integral curves of `X_U` through `φ(s)` at `t = 0`; local uniqueness of integral
curves (`isMIntegralCurveAt_eventuallyEq_of_contMDiffAt_boundaryless`) forces them
to agree near `0`.  This is piece (a) of the two steps separating the §2.1.4
foundations from Exercise 1.6.24 (3) (`PetersenLib.exercise1_6_24_ad_skew`). -/
theorem oneParameterSubgroup_mul_eventuallyEq [CompleteSpace E] [BoundarylessManifold I G]
    {φ : ℝ → G} {U : GroupLieAlgebra I G} {s : ℝ} (hφ0 : φ 0 = 1)
    (hφ0' : IsMIntegralCurveAt φ (mulInvariantVectorField U) 0)
    (hφs : IsMIntegralCurveAt φ (mulInvariantVectorField U) s) :
    (fun t => φ (s + t)) =ᶠ[𝓝 0] (fun t => φ s * φ t) := by
  haveI : LieGroup I (minSmoothness ℝ 3) G := by
    rw [minSmoothness_of_isRCLikeNormedField]; infer_instance
  have hleft : IsMIntegralCurveAt (fun t => φ (s + t)) (mulInvariantVectorField U) 0 := by
    have h := hφs.comp_add s
    rw [sub_self] at h
    have hfun : (φ ∘ (· + s)) = (fun t => φ (s + t)) := by
      funext t; simp only [Function.comp_apply]; rw [add_comm]
    rwa [hfun] at h
  have hright : IsMIntegralCurveAt (fun t => φ s * φ t) (mulInvariantVectorField U) 0 :=
    isMIntegralCurveAt_mul_left (φ s) hφ0'
  refine isMIntegralCurveAt_eventuallyEq_of_contMDiffAt_boundaryless ?_ hleft hright ?_
  · exact (contMDiff_mulInvariantVectorField U).contMDiffAt.of_le
      (one_le_two.trans le_minSmoothness)
  · simp only [add_zero, hφ0, mul_one]

omit [IsManifold I ∞ G] in
/-- **Math.** (Petersen §2.1.4, foundations.) *Uniqueness of the flow of a
left-invariant field.* Any integral curve `ψ` of `X_U` at `0` agrees, near `0`,
with the left translate `t ↦ ψ(0)·φ(t)` of the one-parameter subgroup `φ`
through the identity.  Equivalently, right translation by `φ(t)` is the flow of
`X_U`: the flow line through `g` is `θ_t(g) = g·φ(t)`.  This is local uniqueness
of integral curves (`isMIntegralCurveAt_eventuallyEq_of_contMDiffAt_boundaryless`)
combined with left-invariance of `X_U` (`isMIntegralCurveAt_mul_left`). -/
theorem isMIntegralCurveAt_eventuallyEq_mul_left [CompleteSpace E] [BoundarylessManifold I G]
    {φ ψ : ℝ → G} {U : GroupLieAlgebra I G} (hφ0 : φ 0 = 1)
    (hφ : IsMIntegralCurveAt φ (mulInvariantVectorField U) 0)
    (hψ : IsMIntegralCurveAt ψ (mulInvariantVectorField U) 0) :
    ψ =ᶠ[𝓝 0] (fun t => ψ 0 * φ t) := by
  haveI : LieGroup I (minSmoothness ℝ 3) G := by
    rw [minSmoothness_of_isRCLikeNormedField]; infer_instance
  refine isMIntegralCurveAt_eventuallyEq_of_contMDiffAt_boundaryless ?_ hψ
    (isMIntegralCurveAt_mul_left (ψ 0) hφ) ?_
  · exact (contMDiff_mulInvariantVectorField U).contMDiffAt.of_le
      (one_le_two.trans le_minSmoothness)
  · simp only [hφ0, mul_one]

end PetersenLib
