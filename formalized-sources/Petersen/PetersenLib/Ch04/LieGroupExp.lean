import Mathlib.Analysis.SpecialFunctions.Exponential
import PetersenLib.Ch02.LieGroups

/-!
# Petersen Ch. 4, §4.4.1 — the exponential map and the adjoint action

Petersen §4.4.1 introduces, for a Lie group `G` with Lie algebra `𝔤`, the
exponential map `exp : 𝔤 → G` (each `t ↦ exp(tX)` being the one-parameter
subgroup obtained by integrating the left-invariant vector field generated by
`X`), and the adjoint action `Ad : G → Aut(𝔤)`, `Ad_g = d(x ↦ gxg⁻¹)|₁`,
related to the exponential by `exp(t·Ad_g(X)) = g·exp(tX)·g⁻¹`.

As Petersen himself does for the general theory, the statements are realized
here for **matrix groups**: everything is formalized in the model
`G = Rˣ`, the unit group of a (real, complete) normed algebra `R` — which
covers `GL(V) = (V →L[ℝ] V)ˣ` and all closed matrix groups' ambient `GL` — with
`𝔤 = T_1(Rˣ) ≃ R` as in `PetersenLib/Ch02/LieGroups.lean`.  In this model the
exponential map is the Banach-algebra exponential series `NormedSpace.exp`
(which, in current Mathlib, takes no scalar-field argument; over `ℝ` it is the
classical series `∑ Xⁿ/n!`).

* `lieAlgebraExpMap` — the exponential map `t ↦ exp(tX)`, with the
  one-parameter-subgroup laws `lieAlgebraExpMap_zero`, `lieAlgebraExpMap_add`,
  and the `Rˣ`-valued version `lieAlgebraExpMapUnits` (inverse `exp(−tX)`).
* `matrixExpIsIntegralCurve` — `d/dt exp(tX) = exp(t₀X)·X` at `t = t₀`: the
  curve `t ↦ exp(tX)` is the integral curve through `1` of the left-invariant
  vector field generated by `X` (whose value at `g` is `g·X` by
  `mulInvariantVectorField_units_apply`); restated against Ch. 2's invariant
  field in `matrixExpIsIntegralCurve_mulInvariant`.
* `adjointActionOfLieGroup` — the adjoint action `Ad_g : X ↦ g·X·g⁻¹` as an
  `ℝ`-linear map on `𝔤 = R`; it preserves the commutator bracket
  (`adjointActionOfLieGroup_bracket`) and coincides with the differential at
  `1` of the inner automorphism `x ↦ gxg⁻¹` of `Rˣ`
  (`adjointActionOfLieGroup_eq_mfderiv_conj`, via Ch. 2's
  `mfderiv_conj_units`).
* `adjointExpRelation` — `exp(t·Ad_g(X)) = g·exp(tX)·g⁻¹`.

## Design note

Mathlib's global exponential identities (`NormedSpace.exp_add_of_commute`,
`NormedSpace.exp_units_conj`, …) are stated for `ℚ`-normed algebras, and
`NormedAlgebra ℚ R` is not derivable by instance search from
`NormedAlgebra ℝ R`; the two helper lemmas `exp_add_of_commute_real` and
`exp_units_conj_real` re-derive them over `ℝ` from the `_of_mem_ball` versions
together with `expSeries_radius_eq_top ℝ R`.

Reference: Petersen, *Riemannian Geometry* (3rd ed.), §4.4.1, pp. 155–156.
-/

open NormedSpace
open scoped Manifold

noncomputable section

namespace PetersenLib

variable {R : Type*} [NormedRing R] [NormedAlgebra ℝ R] [CompleteSpace R]

/-! ## Exponential identities over `ℝ`

Real-Banach-algebra forms of Mathlib's `ℚ`-algebra exponential identities (see
the design note in the module docstring). -/

/-- **Math.** In a real Banach algebra, commuting elements satisfy
`exp(x + y) = exp(x)·exp(y)` (Petersen §4.4.1; the one-parameter-subgroup law
below is the special case `y = t·x`).  Real-algebra form of Mathlib's
`NormedSpace.exp_add_of_commute`. -/
theorem exp_add_of_commute_real {x y : R} (h : Commute x y) :
    exp (x + y) = exp x * exp y :=
  exp_add_of_commute_of_mem_ball (𝕂 := ℝ) h
    ((expSeries_radius_eq_top ℝ R).symm ▸ edist_lt_top _ _)
    ((expSeries_radius_eq_top ℝ R).symm ▸ edist_lt_top _ _)

/-- **Math.** In a real Banach algebra, the exponential commutes with
conjugation by a unit: `exp(g·x·g⁻¹) = g·exp(x)·g⁻¹` (each term of the series
does).  Real-algebra form of Mathlib's `NormedSpace.exp_units_conj`. -/
theorem exp_units_conj_real (g : Rˣ) (x : R) :
    exp ((g : R) * x * (↑g⁻¹ : R)) = (g : R) * exp x * (↑g⁻¹ : R) := by
  have h := (map_exp_of_mem_ball (𝕂 := ℝ)
      (MulSemiringAction.toRingHom (ConjAct Rˣ) R (ConjAct.toConjAct g))
      (continuous_const_smul (ConjAct.toConjAct g)) x
      ((expSeries_radius_eq_top ℝ R).symm ▸ edist_lt_top _ _)).symm
  simpa [MulSemiringAction.toRingHom, ConjAct.units_smul_def] using h

/-! ## The exponential map of the Lie group `Rˣ` -/

/-- **Math.** (Petersen §4.4.1.) The Lie-group exponential map of a matrix
group — here of `G = Rˣ`, the unit group of a real Banach algebra `R`, with
`𝔤 = T_1(Rˣ) ≃ R` — sends `X ∈ 𝔤` to the one-parameter subgroup
`t ↦ exp(tX) = ∑ₙ tⁿXⁿ/n!`, the integral curve through `1` of the
left-invariant vector field generated by `X` (see
`matrixExpIsIntegralCurve`). -/
def lieAlgebraExpMap (X : R) : ℝ → R := fun t => exp (t • X)

omit [CompleteSpace R] in
theorem lieAlgebraExpMap_apply (X : R) (t : ℝ) :
    lieAlgebraExpMap X t = exp (t • X) := rfl

omit [CompleteSpace R] in
/-- **Math.** `exp(0·X) = 1`: the one-parameter subgroup starts at the
identity (Petersen §4.4.1). -/
@[simp]
theorem lieAlgebraExpMap_zero (X : R) : lieAlgebraExpMap X 0 = 1 := by
  simp [lieAlgebraExpMap]

/-- **Math.** The one-parameter-subgroup (homomorphism) property
`exp((s+t)X) = exp(sX)·exp(tX)` (Petersen §4.4.1): `sX` and `tX` commute, so
the exponential of their sum splits. -/
theorem lieAlgebraExpMap_add (X : R) (s t : ℝ) :
    lieAlgebraExpMap X (s + t) = lieAlgebraExpMap X s * lieAlgebraExpMap X t := by
  unfold lieAlgebraExpMap
  rw [add_smul]
  exact exp_add_of_commute_real (((Commute.refl X).smul_left s).smul_right t)

/-- **Math.** (Petersen §4.4.1.) The exponential map lands in the Lie group:
`exp(tX)` is a unit of `R`, with explicit inverse `exp(−tX)` (by the
one-parameter-subgroup law `exp(tX)·exp(−tX) = exp(0) = 1`).  This is the
`Rˣ`-valued exponential map `𝔤 → G` of the matrix group `G = Rˣ`. -/
def lieAlgebraExpMapUnits (X : R) (t : ℝ) : Rˣ where
  val := lieAlgebraExpMap X t
  inv := lieAlgebraExpMap X (-t)
  val_inv := by rw [← lieAlgebraExpMap_add, add_neg_cancel, lieAlgebraExpMap_zero]
  inv_val := by rw [← lieAlgebraExpMap_add, neg_add_cancel, lieAlgebraExpMap_zero]

@[simp]
theorem lieAlgebraExpMapUnits_val (X : R) (t : ℝ) :
    (lieAlgebraExpMapUnits X t : R) = lieAlgebraExpMap X t := rfl

@[simp]
theorem lieAlgebraExpMapUnits_inv (X : R) (t : ℝ) :
    ↑(lieAlgebraExpMapUnits X t)⁻¹ = lieAlgebraExpMap X (-t) := rfl

/-- `exp(tX)` is a unit of `R` (Petersen §4.4.1). -/
theorem isUnit_lieAlgebraExpMap (X : R) (t : ℝ) : IsUnit (lieAlgebraExpMap X t) :=
  (lieAlgebraExpMapUnits X t).isUnit

/-- **Math.** The homomorphism property at the group level: `t ↦ exp(tX)` is a
one-parameter subgroup `ℝ → Rˣ` (Petersen §4.4.1). -/
theorem lieAlgebraExpMapUnits_add (X : R) (s t : ℝ) :
    lieAlgebraExpMapUnits X (s + t)
      = lieAlgebraExpMapUnits X s * lieAlgebraExpMapUnits X t :=
  Units.ext (lieAlgebraExpMap_add X s t)

/-! ## `t ↦ exp(tX)` is the integral curve of the invariant field -/

/-- **Math.** (Petersen §4.4.1.) The defining property of the Lie-group
exponential map, in the matrix model `G = Rˣ`:

  `d/dt exp(tX) |_{t = t₀} = exp(t₀X)·X`.

Since the left-invariant vector field generated by `X ∈ 𝔤 ≃ R` has value
`g·X` at `g` (`mulInvariantVectorField_units_apply`), this says exactly that
`t ↦ exp(tX)` is the integral curve through `1` of that invariant field — the
curve whose existence defines `exp` for a general Lie group; see
`matrixExpIsIntegralCurve_mulInvariant` for the statement against Ch. 2's
invariant field. -/
theorem matrixExpIsIntegralCurve (X : R) (t₀ : ℝ) :
    HasDerivAt (lieAlgebraExpMap X) (lieAlgebraExpMap X t₀ * X) t₀ :=
  hasDerivAt_exp_smul_const X t₀

/-- **Math.** (Petersen §4.4.1.) Restatement of `matrixExpIsIntegralCurve`
against the left-invariant vector field of Ch. 2: the velocity of
`t ↦ exp(tX)` at `t₀` is the value of `mulInvariantVectorField X` at the curve
point `exp(t₀X) ∈ Rˣ`, i.e. the curve integrates the invariant field. -/
theorem matrixExpIsIntegralCurve_mulInvariant (X : GroupLieAlgebra 𝓘(ℝ, R) Rˣ) (t₀ : ℝ) :
    HasDerivAt (lieAlgebraExpMap (unitsLieAlgebraToRing X))
      (mulInvariantVectorField X (lieAlgebraExpMapUnits (unitsLieAlgebraToRing X) t₀)) t₀ := by
  rw [mulInvariantVectorField_units_apply, lieAlgebraExpMapUnits_val]
  exact matrixExpIsIntegralCurve _ t₀

/-! ## The adjoint action -/

/-- **Math.** (Petersen §4.4.1.) The adjoint action of the Lie group on its
Lie algebra, in the matrix model `G = Rˣ`, `𝔤 ≃ R`: for `g ∈ G`,

  `Ad_g : 𝔤 → 𝔤`, `Ad_g(X) = g·X·g⁻¹`,

an `ℝ`-linear map (conjugation is linear in `X`).  For a general Lie group
`Ad_g` is *defined* as the differential at `1` of the inner automorphism
`x ↦ gxg⁻¹`; in this model that differential is exactly conjugation
(`adjointActionOfLieGroup_eq_mfderiv_conj`, via Ch. 2's
`mfderiv_conj_units`). -/
def adjointActionOfLieGroup (g : Rˣ) : R →ₗ[ℝ] R :=
  (LinearMap.mulLeft ℝ (g : R)).comp (LinearMap.mulRight ℝ ((g⁻¹ : Rˣ) : R))

omit [CompleteSpace R] in
@[simp]
theorem adjointActionOfLieGroup_apply (g : Rˣ) (x : R) :
    adjointActionOfLieGroup g x = (g : R) * x * (↑g⁻¹ : R) := by
  simp [adjointActionOfLieGroup, mul_assoc]

omit [CompleteSpace R] in
/-- **Math.** (Petersen §4.4.1.) `Ad_g` is an automorphism of the Lie algebra:
it preserves the bracket, which on `𝔤 ≃ R` is the commutator
(`gl_bracket_eq_commutator`, Lemma 2.1.8):

  `Ad_g(xy − yx) = Ad_g(x)·Ad_g(y) − Ad_g(y)·Ad_g(x)`.

The proof is the ring computation `g·xy·g⁻¹ = (g·x·g⁻¹)(g·y·g⁻¹)` using
`g⁻¹·g = 1`. -/
theorem adjointActionOfLieGroup_bracket (g : Rˣ) (x y : R) :
    adjointActionOfLieGroup g (x * y - y * x)
      = adjointActionOfLieGroup g x * adjointActionOfLieGroup g y
        - adjointActionOfLieGroup g y * adjointActionOfLieGroup g x := by
  simp only [map_sub, adjointActionOfLieGroup_apply]
  simp [mul_assoc]

/-- **Math.** (Petersen §4.4.1.) In the matrix model the abstract definition
of the adjoint action agrees with `adjointActionOfLieGroup`: `Ad_g(X)` is the
differential at `1 ∈ Rˣ` of the inner automorphism `x ↦ gxg⁻¹`, applied to
`X ∈ 𝔤 = T_1(Rˣ)` (Ch. 2's `mfderiv_conj_units`). -/
theorem adjointActionOfLieGroup_eq_mfderiv_conj (g : Rˣ) (X : GroupLieAlgebra 𝓘(ℝ, R) Rˣ) :
    adjointActionOfLieGroup g (unitsLieAlgebraToRing X)
      = mfderiv 𝓘(ℝ, R) 𝓘(ℝ, R) (fun x : Rˣ => g * x * g⁻¹) 1 X := by
  rw [mfderiv_conj_units, adjointActionOfLieGroup_apply]

/-! ## The adjoint action and the exponential map -/

/-- **Math.** (Petersen §4.4.1.) The exponential map intertwines the adjoint
action on the Lie algebra with conjugation on the group:

  `exp(t·Ad_g(X)) = g·exp(tX)·g⁻¹`.

Indeed `t·(g·X·g⁻¹) = g·(tX)·g⁻¹` (scalars move through the products), and the
exponential commutes with conjugation term by term
(`exp_units_conj_real`). -/
theorem adjointExpRelation (g : Rˣ) (X : R) (t : ℝ) :
    exp (t • adjointActionOfLieGroup g X) = (g : R) * exp (t • X) * (↑g⁻¹ : R) := by
  have h : t • adjointActionOfLieGroup g X = (g : R) * (t • X) * (↑g⁻¹ : R) := by
    rw [adjointActionOfLieGroup_apply, mul_smul_comm, smul_mul_assoc]
  rw [h]
  exact exp_units_conj_real g (t • X)

/-- `adjointExpRelation` restated through `lieAlgebraExpMap`: the
one-parameter subgroup of `Ad_g(X)` is the conjugate by `g` of the
one-parameter subgroup of `X` (Petersen §4.4.1). -/
theorem lieAlgebraExpMap_adjointAction (g : Rˣ) (X : R) (t : ℝ) :
    lieAlgebraExpMap (adjointActionOfLieGroup g X) t
      = (g : R) * lieAlgebraExpMap X t * (↑g⁻¹ : R) :=
  adjointExpRelation g X t

/-- `adjointExpRelation` at the group level, as an identity in `Rˣ`
(Petersen §4.4.1). -/
theorem lieAlgebraExpMapUnits_adjointAction (g : Rˣ) (X : R) (t : ℝ) :
    lieAlgebraExpMapUnits (adjointActionOfLieGroup g X) t
      = g * lieAlgebraExpMapUnits X t * g⁻¹ := by
  refine Units.ext ?_
  simpa using adjointExpRelation g X t

end PetersenLib
