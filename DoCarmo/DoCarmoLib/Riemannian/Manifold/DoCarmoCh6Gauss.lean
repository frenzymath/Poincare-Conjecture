import DoCarmoLib.Riemannian.Manifold.DoCarmoCh6Fundamental

/-!
# do Carmo Chapter 6, Theorem 2.5 — Gauss' theorem

**Gauss' theorem** (`thm:dc-ch6-2-5`): for orthonormal `x, y ∈ T_pM`,

`K(x,y) − K̄(x,y) = ⟨B(x,x), B(y,y)⟩ − |B(x,y)|²`,

the difference of the sectional curvatures of the immersed manifold and of the
ambient manifold in the plane spanned by `x, y`. Following do Carmo's own
Remark 3.2, we obtain it as the special case `Z = X`, `T = Y` of the Gauss
equation (`prop:dc-ch6-3-1`, `gauss_equation`), rather than by his direct
normal-frame computation:

* `inducedCurvature_inner_sub_curvature_inner` — the difference identity
  `⟨R(X,Y)X, Y⟩ − ⟨R̄(X,Y)X, Y⟩ = ⟨B(X,X), B(Y,Y)⟩ − ⟨B(X,Y), B(X,Y)⟩`
  for tangent fields, no normalization required;
* `gauss_theorem` — the statement with sectional-curvature quotients
  `⟨R(X,Y)X,Y⟩/(|X|²|Y|² − ⟨X,Y⟩²)`, for fields with orthonormal values at `p`.

Reference: do Carmo, *Riemannian Geometry*, Ch. 6 §2, Thm. 2.5 and §3 Rem. 3.2.
-/

open scoped ContDiff Manifold Topology Bundle

noncomputable section

namespace Riemannian

variable {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E] [CompleteSpace E]
  {H : Type*} [TopologicalSpace H] {I : ModelWithCorners ℝ E H}
  {M : Type*} [TopologicalSpace M] [ChartedSpace H M] [IsManifold I ∞ M]

namespace DCImmersedPatch

variable {g : RiemannianMetric I M} (D : DCImmersedPatch I M g)
variable (nabla : AffineConnection I M)

/-- **Math.** do Carmo Ch. 6, Thm. 2.5 / Rem. 3.2 — the **curvature difference
identity**: for tangent fields `X, Y`,

`⟨R(X,Y)X, Y⟩ − ⟨R̄(X,Y)X, Y⟩ = ⟨B(X,X), B(Y,Y)⟩ − ⟨B(X,Y), B(X,Y)⟩`

at every point — the special case `Z = X`, `T = Y` of the Gauss equation,
using the symmetry of `B`. For orthonormal `x = X(p)`, `y = Y(p)` the left side
is the difference `K(x,y) − K̄(x,y)` of sectional curvatures. -/
theorem inducedCurvature_inner_sub_curvature_inner (hLC : nabla.IsLeviCivita g)
    {X Y : SmoothVectorField I M} (hX : D.IsTangentField X)
    (hY : D.IsTangentField Y) (p : M) :
    g.metricInner p (D.inducedCurvature nabla X Y X p) (Y p)
      - g.metricInner p (nabla.curvature X Y X p) (Y p)
      = g.metricInner p (D.secondFundForm nabla X X p)
          (D.secondFundForm nabla Y Y p)
        - g.metricInner p (D.secondFundForm nabla X Y p)
            (D.secondFundForm nabla X Y p) := by
  have hg := D.gauss_equation nabla hLC.2 X Y X hY p
  have hsymm : D.secondFundForm nabla Y X p = D.secondFundForm nabla X Y p := by
    rw [D.secondFundForm_symm nabla hLC.1 hY hX]
  rw [hsymm] at hg
  have hcomm : g.metricInner p (D.secondFundForm nabla Y Y p)
        (D.secondFundForm nabla X X p)
      = g.metricInner p (D.secondFundForm nabla X X p)
        (D.secondFundForm nabla Y Y p) :=
    g.metricInner_comm p _ _
  linarith [hg, hcomm]

/-- **Math.** do Carmo Ch. 6, Thm. 2.5 (**Gauss' theorem**): for `x, y`
orthonormal in `T_pM`,

`K(x,y) − K̄(x,y) = ⟨B(x,x), B(y,y)⟩ − |B(x,y)|²`,

where `K(x,y) = ⟨R(x,y)x, y⟩/(|x|²|y|² − ⟨x,y⟩²)` and `K̄` are the sectional
curvatures of the immersed and the ambient manifold in the plane generated by
`x` and `y` (the normalization is `1` for orthonormal `x, y`). Stated for
tangent fields `X, Y` whose values at `p` are orthonormal. Following
Remark 3.2, this is the special case `Z = X`, `T = Y` of the Gauss
equation. -/
theorem gauss_theorem (hLC : nabla.IsLeviCivita g)
    {X Y : SmoothVectorField I M} (hX : D.IsTangentField X)
    (hY : D.IsTangentField Y) (p : M)
    (hXX : g.metricInner p (X p) (X p) = 1)
    (hYY : g.metricInner p (Y p) (Y p) = 1)
    (hXY : g.metricInner p (X p) (Y p) = 0) :
    g.metricInner p (D.inducedCurvature nabla X Y X p) (Y p)
        / (g.metricInner p (X p) (X p) * g.metricInner p (Y p) (Y p)
            - g.metricInner p (X p) (Y p) ^ 2)
      - g.metricInner p (nabla.curvature X Y X p) (Y p)
        / (g.metricInner p (X p) (X p) * g.metricInner p (Y p) (Y p)
            - g.metricInner p (X p) (Y p) ^ 2)
      = g.metricInner p (D.secondFundForm nabla X X p)
          (D.secondFundForm nabla Y Y p)
        - g.metricInner p (D.secondFundForm nabla X Y p)
            (D.secondFundForm nabla X Y p) := by
  rw [hXX, hYY, hXY]
  norm_num
  exact D.inducedCurvature_inner_sub_curvature_inner nabla hLC hX hY p

end DCImmersedPatch

end Riemannian
