# Lean / Lake build artifacts
.lake/
build/
*.olean
*.ilean
*.trace

# Blueprint / web build output
_site/
blueprint/print/
blueprint/web/
*.aux
*.log
*.pdf.bak

# Editor / OS
.DS_Store
*.swp
.idea/
.vscode/

# Agent / workspace tooling (not part of the clean repo)
.archon-horizon/
.git.disabled/

# hgraph generated graph data (regenerated from blueprint by `hgraph sync`)
# `**/` so it matches at every project depth, not just the repo root.
**/hgraph/nodes/
**/hgraph/edges/

# Per-project dashboards are build intermediates; the published copies live in docs/
# (built by scripts/build-site.sh). docs/ IS tracked — it is the GitHub Pages source.
/*/dashboard.html
